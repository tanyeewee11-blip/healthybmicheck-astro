---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found — HealthyBMICheck"
  description="Sorry, this page doesn't exist. Find our BMI calculators, calorie tools, and health guides below."
  canonical="https://healthybmicheck.com/404"
>

<style>
  .not-found-wrap {
    max-width: 600px;
    margin: 0 auto;
    padding: 64px 24px 80px;
    text-align: center;
  }

  .not-found-code {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(5rem, 18vw, 8rem);
    color: var(--accent);
    line-height: 1;
    margin-bottom: 8px;
    opacity: 0.25;
  }

  .not-found-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .not-found-desc {
    color: var(--ink2);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  .nf-section-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 14px;
  }

  .nf-tools {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 32px;
    text-align: left;
  }

  .nf-tool {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 14px;
    text-decoration: none;
    transition: border-color .15s, box-shadow .15s;
  }

  .nf-tool:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 10px rgba(45,106,79,.08);
  }

  .nf-tool-icon { font-size: 1.3rem; flex-shrink: 0; }

  .nf-tool-text { flex: 1; }

  .nf-tool-name {
    display: block;
    font-size: .875rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }

  .nf-tool-desc {
    display: block;
    font-size: .75rem;
    color: var(--ink3);
    margin-top: 1px;
  }

  .nf-home-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    border-radius: 100px;
    padding: 12px 24px;
    font-size: .9rem;
    font-weight: 600;
    transition: opacity .15s;
  }

  .nf-home-link:hover { opacity: .88; }

  @media (max-width: 480px) {
    .nf-tools { grid-template-columns: 1fr; }
    .not-found-wrap { padding: 40px 20px 60px; }
  }
</style>

<div class="not-found-wrap">
  <div class="not-found-code">404</div>
  <h1 class="not-found-title">Page not found</h1>
  <p class="not-found-desc">
    This page doesn't exist or may have moved. Try one of our tools below — or head back to the homepage.
  </p>

  <p class="nf-section-label">Popular calculators</p>
  <div class="nf-tools">
    <a class="nf-tool" href="bmi-calculator.html">
      <span class="nf-tool-icon">⚖️</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">BMI Calculator</span>
        <span class="nf-tool-desc">Check your body mass index</span>
      </span>
    </a>
    <a class="nf-tool" href="calorie-calculator.html">
      <span class="nf-tool-icon">🔥</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">Calorie Calculator</span>
        <span class="nf-tool-desc">Find your daily calorie target</span>
      </span>
    </a>
    <a class="nf-tool" href="asian-bmi-calculator.html">
      <span class="nf-tool-icon">🌏</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">Asian BMI Calculator</span>
        <span class="nf-tool-desc">WHO-adjusted thresholds</span>
      </span>
    </a>
    <a class="nf-tool" href="body-fat.html">
      <span class="nf-tool-icon">📊</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">Body Fat Calculator</span>
        <span class="nf-tool-desc">Estimate your body composition</span>
      </span>
    </a>
    <a class="nf-tool" href="ideal-weight.html">
      <span class="nf-tool-icon">🎯</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">Ideal Weight Calculator</span>
        <span class="nf-tool-desc">Based on 4 clinical formulas</span>
      </span>
    </a>
    <a class="nf-tool" href="water-intake.html">
      <span class="nf-tool-icon">💧</span>
      <span class="nf-tool-text">
        <span class="nf-tool-name">Water Intake Calculator</span>
        <span class="nf-tool-desc">Daily hydration by weight</span>
      </span>
    </a>
  </div>

  <a class="nf-home-link" href="/">
    ← Back to all tools
  </a>
</div>

</Base>
