---
import Base from '../layouts/Base.astro';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Calorie Calculator — TDEE & BMR (Mifflin-St Jeor)",
      "description": "Free calorie calculator using Mifflin-St Jeor. Get your TDEE, BMR, and calorie targets for weight loss, maintenance, or muscle gain. Instant results.",
      "author": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com",
        "url": "https://healthybmicheck.com"
      },
      "datePublished": "2025-05-10",
      "dateModified": "2026-06-17",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://healthybmicheck.com/calorie-calculator"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is TDEE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TDEE stands for Total Daily Energy Expenditure — the total calories your body burns each day, including your basal metabolic rate and all physical activity. Eating at your TDEE keeps your weight stable."
          }
        },
        {
          "@type": "Question",
          "name": "What is BMR, and how is it different from TDEE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BMR (Basal Metabolic Rate) is the calories your body burns at complete rest — just to breathe, circulate blood, and maintain organ function. It accounts for 60–75% of your TDEE. TDEE adds your activity on top of BMR. If you did nothing but lie still all day, you would still burn your BMR in calories."
          }
        },
        {
          "@type": "Question",
          "name": "How many calories should I eat to lose weight?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A safe deficit is 500 calories/day below your TDEE, resulting in roughly 0.5 kg (1 lb) of fat loss per week. For slower, easier-to-maintain loss, a 250 calorie deficit works well. Deficits above 1,000 calories/day risk muscle loss and are not recommended without medical supervision."
          }
        },
        {
          "@type": "Question",
          "name": "What formula does this calculator use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Mifflin-St Jeor equation (1990) — considered the most accurate BMR formula for most healthy adults. Men: BMR = (10 × kg) + (6.25 × cm) − (5 × age) + 5. Women: BMR = (10 × kg) + (6.25 × cm) − (5 × age) − 161. BMR is then multiplied by your activity factor to get TDEE."
          }
        },
        {
          "@type": "Question",
          "name": "Should I eat back calories burned during exercise?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This calculator already accounts for your activity level, so you generally do not need to eat back exercise calories for planned workouts. For unexpectedly intense sessions, eating back 50% of the estimated burn is a reasonable approach — fitness trackers tend to overestimate by 20–30%."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my calorie result different from other calculators?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Different calculators use different formulas. Common ones include Mifflin-St Jeor, Harris-Benedict, and Katch-McArdle (which requires body fat percentage). Research shows Mifflin-St Jeor is the most accurate for the general population. Small differences between calculators (±100–150 kcal) are normal."
          }
        },
        {
          "@type": "Question",
          "name": "How do common Malaysian dishes fit into my daily calorie target?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Popular Malaysian dishes vary widely in calorie density. Nasi lemak with sambal, egg, and anchovies runs roughly 400–650 kcal depending on portion and sides; char kway teow is typically 600–750 kcal; roti canai with dhal is around 300 kcal per piece. Once you know your daily target, these fit into your day the same way as any other meal."
          }
        }
      ]
    },
    {
      "@type": "WebApplication",
      "name": "Calorie & TDEE Calculator",
      "url": "https://healthybmicheck.com/calorie-calculator",
      "description": "Calculate your daily calorie needs based on age, weight, height and activity level.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web Browser",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com",
        "url": "https://healthybmicheck.com"
      }
    },
    {
    "@type": "HowTo",
    "name": "How to Calculate Your Daily Calorie Needs",
    "description": "Use our free calorie calculator to find your TDEE and set the right calorie target for weight loss, maintenance, or muscle gain.",
    "totalTime": "PT2M",
    "tool": [
        {
            "@type": "HowToTool",
            "name": "HealthyBMICheck Calorie Calculator"
        }
    ],
    "step": [
        {
            "@type": "HowToStep",
            "name": "Select your sex",
            "text": "Choose male or female to ensure the Mifflin-St Jeor formula uses the correct baseline metabolic rate."
        },
        {
            "@type": "HowToStep",
            "name": "Enter your age, height, and weight",
            "text": "Input your current age in years, height (cm or ft/in), and body weight (kg or lbs). Switch between metric and imperial using the unit toggle."
        },
        {
            "@type": "HowToStep",
            "name": "Choose your activity level",
            "text": "Select the activity level that best matches your typical weekly routine \u2014 from sedentary to very active."
        },
        {
            "@type": "HowToStep",
            "name": "Select your goal",
            "text": "Choose weight loss, maintenance, or muscle gain. The calculator applies the appropriate calorie adjustment to your TDEE."
        },
        {
            "@type": "HowToStep",
            "name": "Read your results",
            "text": "Your BMR, TDEE, and goal-specific calorie target are displayed instantly below the form."
        }
    ]
}
  ]
});

const breadcrumbJson = JSON.stringify({"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthybmicheck.com/"}, {"@type": "ListItem", "position": 2, "name": "Calorie Calculator — TDEE & BMR (Mifflin-St Jeor)", "item": "https://healthybmicheck.com/calorie-calculator"}]});
---

<Base
  breadcrumbJson={breadcrumbJson}
  schemaJson={schemaJson}
  title="Calorie Calculator — TDEE & BMR (Mifflin-St Jeor)"
  description="Free calorie calculator using Mifflin-St Jeor. Get your TDEE, BMR, and calorie targets for weight loss, maintenance, or muscle gain. Instant results."
  canonical="https://healthybmicheck.com/calorie-calculator"
>
<div class="hero">
  <div class="breadcrumb"><a href="/" class="breadcrumb-link">Home</a> › Calorie Calculator</div>
  <h1>Free <em>Calorie</em> Calculator</h1>
  <p>Get your BMR and TDEE instantly — plus calorie targets for weight loss, maintenance, or muscle gain.</p>
</div>

<div class="calc-byline">Reviewed by <strong>Sarah Mitchell, BSc Nutrition</strong> · Last updated: <strong>July 2026</strong></div>

<div class="container">


  <!-- Calculator Card -->
  <div class="card">
    <div class="unit-toggle">
      <button class="active" onclick="setUnit('metric')">Metric (kg / cm)</button>
      <button onclick="setUnit('imperial')">Imperial (lb / in)</button>
    </div>

    <div class="input-group">
      <label>Sex</label>
      <div class="gender-toggle">
        <button class="gender-btn active" onclick="setGender('male', this)">♂ Male</button>
        <button class="gender-btn" onclick="setGender('female', this)">♀ Female</button>
      </div>
    </div>

    <div class="input-group">
      <label for="age">Age</label>
      <div class="input-wrap">
        <input type="number" id="age" placeholder="30" min="15" max="100">
        <span class="unit-badge">yrs</span>
      </div>
    </div>

    <div class="input-group" id="metric-weight-wrap">
      <label for="weight-kg">Weight</label>
      <div class="input-wrap">
        <input type="number" id="weight-kg" placeholder="70" min="20" max="300">
        <span class="unit-badge">kg</span>
      </div>
    </div>
    <div class="input-group" id="imperial-weight-wrap" style="display:none">
      <label for="weight-lb">Weight</label>
      <div class="input-wrap">
        <input type="number" id="weight-lb" placeholder="154" min="44" max="660">
        <span class="unit-badge">lb</span>
      </div>
    </div>

    <div class="input-group" id="metric-height-wrap">
      <label for="height-cm">Height</label>
      <div class="input-wrap">
        <input type="number" id="height-cm" placeholder="170" min="100" max="250">
        <span class="unit-badge">cm</span>
      </div>
    </div>
    <div class="input-group" id="imperial-height-wrap" style="display:none">
      <label>Height</label>
      <div class="input-row">
        <div class="input-wrap">
          <input type="number" id="height-ft" placeholder="5" min="3" max="8" aria-label="Height (feet)">
          <span class="unit-badge">ft</span>
        </div>
        <div class="input-wrap">
          <input type="number" id="height-in" placeholder="7" min="0" max="11" aria-label="Height (inches)">
          <span class="unit-badge">in</span>
        </div>
      </div>
    </div>

    <div class="input-group">
      <label for="activity">Activity Level</label>
      <select id="activity">
        <option value="1.2">Sedentary — desk job, little exercise</option>
        <option value="1.375">Lightly active — exercise 1–3 days/week</option>
        <option value="1.55" selected>Moderately active — exercise 3–5 days/week</option>
        <option value="1.725">Very active — exercise 6–7 days/week</option>
        <option value="1.9">Extra active — physical job or twice-daily training</option>
      </select>
