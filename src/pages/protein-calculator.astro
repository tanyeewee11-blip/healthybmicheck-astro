---

<Base
  breadcrumbJson={breadcrumbJson}
  schemaJson={schemaJson}
  title="Protein Calculator — How Much Protein Per Day? | HealthyBMICheck"
  description="Calculate your daily protein intake based on your weight and goal. Evidence-based targets for weight loss, muscle building, and maintenance. Metric and imperial."
  canonical="https://healthybmicheck.com/protein-calculator.html"
>

<div class="hero">
  <div class="breadcrumb" style="font-size:.8rem;color:var(--ink3);margin-bottom:16px;"><a href="index.html" style="color:var(--ink3);text-decoration:none;">Home</a> › Protein Calculator</div>
  <h1>Daily <em>Protein</em> Calculator</h1>
  <p>Find out exactly how much protein you need per day based on your weight, activity level, and goal — backed by current research.</p>
</div>

<div style="font-size:.8rem;color:var(--ink3);margin:0 auto 24px;max-width:720px;padding:0 20px 16px;border-bottom:1px solid var(--border);">Reviewed by <strong>Sarah Mitchell, BSc Nutrition</strong> · Last updated: <strong>June 2026</strong></div>

<div class="container">

  <div class="card">
    <div class="unit-toggle">
      <button class="active" onclick="setUnit('metric')">Metric (kg)</button>
      <button onclick="setUnit('imperial')">Imperial (lb)</button>
    </div>

    <div class="input-group" id="kg-wrap">
      <label>Body Weight</label>
      <div class="input-wrap">
        <input type="number" id="weight-kg" placeholder="70" min="30" max="300">
        <span class="unit-badge">kg</span>
      </div>
    </div>
    <div class="input-group" id="lb-wrap" style="display:none">
      <label>Body Weight</label>
      <div class="input-wrap">
        <input type="number" id="weight-lb" placeholder="154" min="66" max="660">
        <span class="unit-badge">lb</span>
      </div>
    </div>

    <div class="input-group">
      <label>Your Goal</label>
      <select id="goal-select" style="width:100%;padding:12px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--bg);color:var(--ink1);font-size:.95rem;font-family:inherit;">
        <option value="lose">Weight loss (preserve muscle)</option>
        <option value="maintain" selected>Maintenance / general health</option>
        <option value="build">Muscle building</option>
        <option value="athlete">Athletic performance</option>
        <option value="senior">Healthy ageing (65+)</option>
      </select>
    </div>

    <div class="input-group">
      <label>Activity Level</label>
      <select id="activity-select" style="width:100%;padding:12px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--bg);color:var(--ink1);font-size:.95rem;font-family:inherit;">
        <option value="sedentary">Sedentary (desk job, little exercise)</option>
        <option value="light">Lightly active (1–3 sessions/week)</option>
        <option value="moderate" selected>Moderately active (3–5 sessions/week)</option>
        <option value="active">Very active (6–7 sessions/week)</option>
        <option value="veryactive">Extra active (physical job + training)</option>
      </select>
    </div>

    <button class="calc-btn" onclick="calculate()">Calculate Protein Target →</button>
  </div>

  <!-- Result -->
  <div class="result-card" id="result-card">
    <div style="text-align:center;padding:20px 20px 0;">
      <div id="result-num" style="font-size:2.8rem;font-weight:500;color:var(--accent);font-family:'DM Serif Display',serif;">—</div>
      <div style="font-size:.9rem;color:var(--ink3);margin-top:6px;">grams of protein per day</div>
      <div id="result-per-kg" style="font-size:.82rem;color:var(--ink3);margin-top:4px;"></div>
    </div>

    <div id="breakdown-section" style="display:none;margin-top:16px;padding:0 4px;">
      <div style="font-size:.75rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;">Daily protein range</div>
      <div id="range-row" style="background:var(--surface);border-radius:10px;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div style="text-align:center;">
          <div id="range-low" style="font-size:1.4rem;font-weight:500;color:var(--ink1);">—</div>
          <div style="font-size:.75rem;color:var(--ink3);margin-top:2px;">Minimum</div>
        </div>
        <div style="color:var(--ink3);font-size:1.2rem;">→</div>
        <div style="text-align:center;">
          <div id="range-target" style="font-size:1.8rem;font-weight:500;color:var(--accent);">—</div>
          <div style="font-size:.75rem;color:var(--ink3);margin-top:2px;">Optimal</div>
        </div>
        <div style="color:var(--ink3);font-size:1.2rem;">→</div>
        <div style="text-align:center;">
          <div id="range-high" style="font-size:1.4rem;font-weight:500;color:var(--ink1);">—</div>
          <div style="font-size:.75rem;color:var(--ink3);margin-top:2px;">Upper end</div>
        </div>
      </div>

      <div style="font-size:.75rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;">Per meal (spread across 4 meals)</div>
      <div id="per-meal" style="background:var(--surface);border-radius:10px;padding:14px 16px;text-align:center;font-size:1.2rem;font-weight:500;color:var(--ink1);"></div>

      <div id="food-examples" style="margin-top:10px;"></div>
    </div>

    <div style="margin-top:16px;padding:14px 16px;background:var(--surface);border-radius:10px;font-size:.85rem;line-height:1.7;">
      <strong>Also useful:</strong>
      <a href="macro-calculator.html" style="color:var(--accent);font-weight:500;">Macro Calculator</a> ·
      <a href="calorie-calculator.html" style="color:var(--accent);font-weight:500;">Calorie Calculator</a> ·
      <a href="high-protein-foods.html" style="color:var(--accent);font-weight:500;">High-Protein Foods Guide</a>
    </div>
  </div>

  <div class="article-section">
    <h2>How Much Protein Do You Really Need?</h2>
    <p>The official minimum (RDA) for adults is <strong>0.8 g of protein per kg body weight</strong> — but this is the amount needed to prevent deficiency, not the amount that optimises health, body composition, or performance. Current research suggests substantially higher intakes for most active people:</p>

    <div class="card" style="padding:0;overflow:hidden;margin:16px 0;">
      <table>
        <thead><tr><th>Goal / Situation</th><th>Protein target</th><th>For 70 kg person</th></tr></thead>
        <tbody>
          <tr><td>Sedentary adult (minimum)</td><td>0.8 g/kg</td><td>56 g/day</td></tr>
          <tr class="highlight-row"><td>General health / maintenance</td><td>1.0–1.2 g/kg</td><td>70–84 g/day</td></tr>
          <tr><td>Weight loss (muscle preservation)</td><td>1.2–1.6 g/kg</td><td>84–112 g/day</td></tr>
          <tr class="highlight-row"><td>Muscle building</td><td>1.6–2.2 g/kg</td><td>112–154 g/day</td></tr>
          <tr><td>Athletic performance</td><td>1.6–2.4 g/kg</td><td>112–168 g/day</td></tr>
          <tr class="highlight-row"><td>Adults 65+ (sarcopenia prevention)</td><td>1.2–1.6 g/kg</td><td>84–112 g/day</td></tr>
        </tbody>
      </table>
    </div>

    <h2>Why Higher Protein Helps With Weight Loss</h2>
    <p>Protein is the most powerful macronutrient for weight management, for three reasons:</p>
    <ul>
      <li><strong>Highest satiety:</strong> Protein reduces hunger hormones (ghrelin) and increases fullness hormones (PYY, GLP-1) more than carbohydrates or fat, leading to reduced calorie intake without deliberate restriction</li>
      <li><strong>Highest thermic effect:</strong> 20–30% of protein calories are used in digestion and metabolism itself — compared to 5–10% for carbohydrates and 0–3% for fat. A 150 kcal serving of chicken effectively provides only ~120 kcal net</li>
      <li><strong>Muscle preservation:</strong> During a calorie deficit, high protein intake (1.2–1.6 g/kg) preserves lean muscle mass — which maintains metabolic rate and body composition</li>
    </ul>
    <div class="callout"><p>💡 A meta-analysis of 87 studies found that higher protein diets consistently produce more weight loss and muscle preservation than standard protein diets, even at the same calorie intake (Wycherley et al., 2012).</p></div>

    <h2>Best High-Protein Foods</h2>
    <div class="card" style="padding:0;overflow:hidden;margin:16px 0;">
      <table>
        <thead><tr><th>Food</th><th>Protein per 100g</th><th>Calories per 100g</th></tr></thead>
        <tbody>
          <tr><td>Chicken breast (cooked)</td><td>31g</td><td>165 kcal</td></tr>
          <tr class="highlight-row"><td>Canned tuna (in water)</td><td>26g</td><td>109 kcal</td></tr>
          <tr><td>Beef (lean, cooked)</td><td>26g</td><td>215 kcal</td></tr>
          <tr class="highlight-row"><td>Eggs (whole)</td><td>13g</td><td>155 kcal</td></tr>
          <tr><td>Greek yoghurt (0% fat)</td><td>10g</td><td>59 kcal</td></tr>
          <tr class="highlight-row"><td>Cottage cheese (low-fat)</td><td>12g</td><td>84 kcal</td></tr>
          <tr><td>Lentils (cooked)</td><td>9g</td><td>116 kcal</td></tr>
          <tr class="highlight-row"><td>Tofu (firm)</td><td>8g</td><td>76 kcal</td></tr>
          <tr><td>Edamame (cooked)</td><td>11g</td><td>121 kcal</td></tr>
          <tr class="highlight-row"><td>Whey protein powder</td><td>75–80g</td><td>~370 kcal</td></tr>
        </tbody>
      </table>
    </div>
    <p>For more ideas and meal planning tips, see our <a href="high-protein-foods.html">High-Protein Foods Guide</a>.</p>

    <h2>Protein Timing: Does It Matter?</h2>
    <p>Total daily protein intake matters more than timing, but distributing protein evenly across meals does enhance muscle protein synthesis. Research supports:</p>
    <ul>
      <li><strong>Spread across 3–4 meals:</strong> Aiming for 25–40g of protein per meal maximises muscle protein synthesis at each meal. Eating 150g in one sitting is less effective than 40g per meal × 4 meals</li>
      <li><strong>Post-workout:</strong> Consuming 20–40g of protein within 1–2 hours of resistance training slightly enhances muscle repair</li>
      <li><strong>Pre-sleep casein:</strong> Slow-digesting casein protein (cottage cheese, Greek yoghurt) before bed sustains overnight muscle protein synthesis</li>
    </ul>
  </div>

  <div class="faq-section">
    <h2 class="section-title">Frequently Asked Questions</h2>
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">How much protein do I need per day?</button>
      <div class="faq-a">Protein needs depend on your goal and activity level. The minimum for sedentary adults is 0.8 g per kg body weight. For weight loss, 1.2–1.6 g/kg helps preserve muscle. For muscle building, 1.6–2.2 g/kg is optimal. Older adults need about 1.2–1.6 g/kg to counteract age-related muscle loss.</div>
    </div>
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">Can you eat too much protein?</button>
      <div class="faq-a">For healthy adults, protein intakes up to 2.5 g/kg body weight are generally safe. Very high intakes above 3.5 g/kg may cause digestive discomfort in some people. People with kidney disease should consult a doctor before increasing protein intake, as impaired kidneys may have difficulty processing high protein loads.</div>
    </div>
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">Does protein help with weight loss?</button>
      <div class="faq-a">Yes. Protein has the highest thermic effect of all macronutrients (20–30% of protein calories are burned during digestion). It also promotes satiety more than carbohydrates or fat. During a calorie deficit, higher protein intake helps preserve lean muscle mass, which keeps metabolic rate higher.</div>
    </div>
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">What are the best high-protein foods?</button>
      <div class="faq-a">The best high-protein foods include chicken breast (31g/100g), canned tuna (26g/100g), eggs (13g/100g), Greek yoghurt (10g/100g), cottage cheese (12g/100g), lentils (9g/100g), and tofu (8g/100g). For plant-based diets, combining legumes with grains provides all essential amino acids.</div>
    </div>
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">Are plant proteins as good as animal proteins?</button>
      <div class="faq-a">Plant proteins are slightly lower in bioavailability and most are incomplete (missing one or more essential amino acids). However, a varied plant-based diet combining different protein sources easily meets protein needs. Research shows plant-protein diets can achieve the same muscle building and weight loss results as animal-protein diets when total intake is matched.</div>
    </div>
  </div>

  <div class="related">
    <h3>Related Calculators & Guides</h3>
    <div class="related-links">
      <a href="macro-calculator.html">Macro Calculator</a>
      <a href="calorie-calculator.html">Calorie Calculator</a>
      <a href="high-protein-foods.html">High-Protein Foods Guide</a>
      <a href="protein-for-weight-loss.html">Protein for Weight Loss</a>
      <a href="bmr-calculator.html">BMR Calculator</a>
      <a href="calories-burned-calculator.html">Calories Burned Calculator</a>
      <a href="muscle-vs-fat.html">Muscle vs Fat</a>
    </div>
  </div>

</div>

<div class="cta-block">
  <p style="font-size:.8rem;font-weight:600;color:#7EC8A4;text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;">Next step</p>
  <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:#fff;margin-bottom:8px;line-height:1.2;">Complete your nutrition targets</h2>
  <p style="font-size:.9rem;color:rgba(255,255,255,.6);margin-bottom:20px;max-width:400px;margin-left:auto;margin-right:auto;">Set your calorie target and full macro breakdown.</p>
  <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">
    <a href="macro-calculator.html" style="display:inline-flex;align-items:center;gap:8px;background:#2D6A4F;color:#fff;text-decoration:none;border-radius:100px;padding:12px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;">🥩 Macro Calculator →</a>
    <a href="calorie-calculator.html" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);color:#fff;text-decoration:none;border-radius:100px;padding:11px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;border:1.5px solid rgba(255,255,255,.4);">🔥 Calorie Calculator →</a>
    <a href="high-protein-foods.html" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);color:#fff;text-decoration:none;border-radius:100px;padding:11px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;border:1.5px solid rgba(255,255,255,.4);">🍗 High-Protein Foods →</a>
  </div>
</div>

<div style="max-width:720px;margin:0 auto;padding:0 20px 40px;">
  <div style="background:#F0F7F4;border:1px solid #B7DDD0;border-radius:12px;padding:20px 24px;font-size:0.82rem;color:#2D4A3E;line-height:1.8;">
    <strong style="display:block;margin-bottom:8px;">📚 References</strong>
    <ol style="margin:8px 0 8px 18px;padding:0;">
      <li>Morton RW et al. (2018). <em>A systematic review, meta-analysis and meta-regression of the effect of protein supplementation on resistance training-induced gains in muscle mass and strength</em>. Br J Sports Med. <a href="https://doi.org/10.1136/bjsports-2017-097608" style="color:var(--accent);">doi:10.1136/bjsports-2017-097608</a></li>
      <li>Wycherley TP et al. (2012). <em>Effects of energy-restricted high-protein, low-fat diet relative to a conventional high-carbohydrate, low-fat diet on weight loss</em>. Am J Clin Nutr. <a href="https://doi.org/10.3945/ajcn.112.044321" style="color:var(--accent);">doi:10.3945/ajcn.112.044321</a></li>
      <li>Stokes T et al. (2018). <em>Recent perspectives regarding the role of dietary protein for the promotion of muscle hypertrophy with resistance exercise training</em>. Nutrients. <a href="https://doi.org/10.3390/nu10020180" style="color:var(--accent);">doi:10.3390/nu10020180</a></li>
    </ol>
    Not a substitute for professional medical or dietary advice. Last updated June 2026.
  </div>
</div>

<script>
let unit = 'metric';

function setUnit(u) {
  unit = u;
  document.querySelectorAll('.unit-toggle button').forEach((b,i) => b.classList.toggle('active', (u==='metric'&&i===0)||(u==='imperial'&&i===1)));
  document.getElementById('kg-wrap').style.display = u==='metric' ? '' : 'none';
  document.getElementById('lb-wrap').style.display = u==='imperial' ? '' : 'none';
}

function calculate() {
  let weightKg;
  if (unit === 'metric') {
    weightKg = parseFloat(document.getElementById('weight-kg').value);
  } else {
    weightKg = parseFloat(document.getElementById('weight-lb').value) * 0.453592;
  }

  const goal = document.getElementById('goal-select').value;
  const activity = document.getElementById('activity-select').value;

  if (!weightKg || weightKg < 30) { alert('Please enter a valid weight.'); return; }

  // Protein multipliers (g/kg) based on goal and activity
  const ranges = {
    lose:      { low: 1.2, opt: 1.5, high: 1.8 },
    maintain:  { low: 0.8, opt: 1.1, high: 1.4 },
    build:     { low: 1.6, opt: 2.0, high: 2.4 },
    athlete:   { low: 1.6, opt: 2.0, high: 2.4 },
    senior:    { low: 1.2, opt: 1.4, high: 1.6 },
  };

  // Activity adjustment
  const actAdj = { sedentary: 0, light: 0.1, moderate: 0.2, active: 0.3, veryactive: 0.4 };
  const adj = actAdj[activity] || 0;

  const r = ranges[goal];
  const low = Math.round((r.low + adj * 0.3) * weightKg);
  const opt = Math.round((r.opt + adj * 0.3) * weightKg);
  const high = Math.round((r.high + adj * 0.2) * weightKg);
  const perMeal = Math.round(opt / 4);
  const perKg = (opt / weightKg).toFixed(1);

  document.getElementById('result-num').textContent = opt + 'g';
  document.getElementById('result-per-kg').textContent = `(${perKg} g per kg body weight)`;
  document.getElementById('range-low').textContent = low + 'g';
  document.getElementById('range-target').textContent = opt + 'g';
  document.getElementById('range-high').textContent = high + 'g';
  document.getElementById('per-meal').textContent = `~${perMeal}g per meal`;

  // Food examples
  const foods = [
    { food: 'Chicken breast (cooked)', g_per_100: 31 },
    { food: 'Canned tuna', g_per_100: 26 },
    { food: 'Greek yoghurt (0%)', g_per_100: 10 },
    { food: 'Eggs (whole)', g_per_100: 13 },
  ];
  const examples = foods.map(f => {
    const grams = Math.round(opt / (f.g_per_100 / 100));
    return `<div style="display:flex;justify-content:space-between;padding:7px 12px;background:var(--surface);border-radius:8px;font-size:.82rem;"><span style="color:var(--ink2);">${f.food}</span><strong>${grams}g</strong></div>`;
  });
  document.getElementById('food-examples').innerHTML = `
    <div style="font-size:.75rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--ink3);margin:10px 0 8px;">To hit ${opt}g from single sources</div>
    <div style="display:flex;flex-direction:column;gap:5px;">${examples.join('')}</div>
    <div style="font-size:.78rem;color:var(--ink3);margin-top:8px;">In practice, combine multiple sources across meals.</div>
  `;

  document.getElementById('breakdown-section').style.display = '';
  document.getElementById('result-card').classList.add('visible');
  document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}
</script>

</Base>
