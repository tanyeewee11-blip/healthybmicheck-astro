<script>
function showSex(sex) {
  const female = document.getElementById('section-female');
  const male = document.getElementById('section-male');
  const btnBoth = document.getElementById('btn-both');
  const btnFemale = document.getElementById('btn-female');
  const btnMale = document.getElementById('btn-male');
  [btnBoth, btnFemale, btnMale].forEach(b => {
    b.style.background = 'transparent';
    b.style.color = 'var(--ink2)';
    b.style.borderColor = 'var(--border)';
  });
  const activeBtn = sex === 'both' ? btnBoth : sex === 'female' ? btnFemale : btnMale;
  activeBtn.style.background = 'var(--accent)';
  activeBtn.style.color = '#fff';
  activeBtn.style.borderColor = 'var(--accent)';
  female.style.display = (sex === 'both' || sex === 'female') ? '' : 'none';
  male.style.display = (sex === 'both' || sex === 'male') ? '' : 'none';
}
</script>



