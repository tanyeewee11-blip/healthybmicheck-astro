---
import Base from '../layouts/Base.astro';
const main = "<div class=\"page-wrap\">\n\n  <h1>Contact Us</h1>\n  <p class=\"subtitle\">Have a question about one of our calculators, spotted an error, or want to share feedback? We read every message and aim to respond within 2 business days.</p>\n\n  <div class=\"contact-grid\">\n    <div class=\"contact-card\">\n      <div class=\"icon\">📧</div>\n      <h3>General Enquiries</h3>\n      <p>Questions about our tools, how they work, or anything else.</p>\n      <a href=\"mailto:hello@healthybmicheck.com\">hello@healthybmicheck.com</a>\n    </div>\n    <div class=\"contact-card\">\n      <div class=\"icon\">🐛</div>\n      <h3>Report an Issue</h3>\n      <p>Found a calculation error or a broken feature? Let us know so we can fix it quickly.</p>\n      <a href=\"mailto:hello@healthybmicheck.com\">Report a bug</a>\n    </div>\n    <div class=\"contact-card\">\n      <div class=\"icon\">🌏</div>\n      <h3>Based In</h3>\n      <p>HealthyBMICheck.com is an independent project based in Malaysia, serving a global audience.</p>\n      <span style=\"color:var(--accent);font-size:.875rem;\">Malaysia (UTC+8)</span>\n    </div>\n    <div class=\"contact-card\">\n      <div class=\"icon\">⏱️</div>\n      <h3>Response Time</h3>\n      <p>We read every message and aim to respond within 2 business days (Mon–Fri, UTC+8).</p>\n      <span style=\"color:var(--accent);font-size:.875rem;\">Usually within 48 hours</span>\n    </div>\n  </div>\n\n  <div class=\"form-card\">\n    <h2>Send a Message</h2>\n    <form id=\"contact-form\" action=\"https://api.web3forms.com/submit\" method=\"POST\">\n      <input type=\"hidden\" name=\"access_key\" value=\"9639bd2b-67b7-4dd4-a43e-5dc234c50782\">\n      <input type=\"hidden\" name=\"subject\" id=\"form-subject\" value=\"New message from HealthyBMICheck.com\">\n      <input type=\"hidden\" name=\"from_name\" value=\"HealthyBMICheck Contact Form\">\n      <input type=\"checkbox\" name=\"botcheck\" style=\"display:none;\">\n\n      <div class=\"input-row\">\n        <div class=\"field\">\n          <label for=\"fname\">First name</label>\n          <input type=\"text\" id=\"fname\" name=\"first_name\" placeholder=\"Alex\" required>\n        </div>\n        <div class=\"field\">\n          <label for=\"lname\">Last name</label>\n          <input type=\"text\" id=\"lname\" name=\"last_name\" placeholder=\"Smith\">\n        </div>\n      </div>\n      <div class=\"field\">\n        <label for=\"email\">Email address</label>\n        <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"you@example.com\" required>\n      </div>\n      <div class=\"field\">\n        <label for=\"subject\">Subject</label>\n        <select id=\"subject\" name=\"topic\">\n          <option value=\"\">Select a topic…</option>\n          <option value=\"Question about a calculator\">Question about a calculator</option>\n          <option value=\"Report a bug or error\">Report a bug or error</option>\n          <option value=\"General feedback\">General feedback</option>\n          <option value=\"Something else\">Something else</option>\n        </select>\n      </div>\n      <div class=\"field\">\n        <label for=\"message\">Message</label>\n        <textarea id=\"message\" name=\"message\" placeholder=\"Tell us what's on your mind…\" required></textarea>\n      </div>\n      <button class=\"submit-btn\" type=\"submit\" id=\"submit-btn\">Send Message →</button>\n      <div class=\"success-msg\" id=\"success-msg\" style=\"display:none;\">\n        ✅ Thanks for reaching out! We'll get back to you within 2 business days.\n      </div>\n      <div id=\"error-msg\" style=\"display:none;margin-top:12px;padding:12px;background:#FADFDF;border-radius:8px;color:#B83232;font-size:.875rem;\">\n        ❌ Something went wrong. Please try again or email us directly at <a href=\"mailto:hello@healthybmicheck.com\" style=\"color:#B83232;\">hello@healthybmicheck.com</a>\n      </div>\n    </form>\n  </div>\n\n  <div class=\"faq-block\">\n    <h2>Common Questions</h2>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Are your calculators medically accurate?</button>\n      <div class=\"faq-a\">Our calculators use established scientific formulas widely used in clinical and research settings — the Mifflin-St Jeor equation for calories, WHO BMI classifications, the U.S. Navy method for body fat, and multiple peer-reviewed ideal weight formulas. Results are estimates based on population averages and should be used as a general guide, not a medical diagnosis. For personalised health advice, please consult a qualified healthcare professional.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Do you store my data?</button>\n      <div class=\"faq-a\">No. All calculations on this site run entirely in your browser — no data is sent to our servers. We do not collect, store, or share any health information you enter into our calculators. See our <a href=\"privacy.html\">Privacy Policy</a> for full details.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Can I suggest a new calculator or article?</button>\n      <div class=\"faq-a\">Absolutely — we love hearing what tools our readers find useful. Send us a message using the form above with your suggestion and we will consider it for a future update.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-q\" onclick=\"toggleFaq(this)\">I found a calculation error — what should I do?</button>\n      <div class=\"faq-a\">Please let us know immediately using the form above or by emailing hello@healthybmicheck.com. Describe which calculator, what inputs you used, and what result you got. We take accuracy seriously and will investigate and correct any errors promptly.</div>\n    </div>\n  </div>\n\n</div>\n\n\n\n<script>\n  // Web3Forms submission handler\n  document.getElementById('contact-form').addEventListener('submit', async function(e) {\n    e.preventDefault();\n    const btn = document.getElementById('submit-btn');\n    const successMsg = document.getElementById('success-msg');\n    const errorMsg = document.getElementById('error-msg');\n\n    // Update subject with selected topic\n    const topic = document.getElementById('subject').value;\n    if (topic) {\n      document.getElementById('form-subject').value = 'HealthyBMICheck: ' + topic;\n    }\n\n    btn.textContent = 'Sending…';\n    btn.disabled = true;\n    successMsg.style.display = 'none';\n    errorMsg.style.display = 'none';\n\n    try {\n      const formData = new FormData(this);\n      const response = await fetch('https://api.web3forms.com/submit', {\n        method: 'POST',\n        body: formData\n      });\n      const data = await response.json();\n\n      if (data.success) {\n        successMsg.style.display = 'block';\n        this.reset();\n        btn.textContent = 'Send Message →';\n        btn.disabled = false;\n      } else {\n        throw new Error(data.message);\n      }\n    } catch (err) {\n      errorMsg.style.display = 'block';\n      btn.textContent = 'Send Message →';\n      btn.disabled = false;\n    }\n  });\n\n  function toggleFaq(btn) {\n    btn.classList.toggle('open');\n    btn.nextElementSibling.classList.toggle('open');\n  }\n</script>\n\n<div style=\"padding-bottom: 20px;\"></div>";
---

<Base
  title="Contact Us — HealthyBMICheck.com"
  description="Contact the HealthyBMICheck.com team. Send us a question, report an issue, or share feedback about our free health calculators."
  canonical="https://healthybmicheck.com/contact.html"
>
  <Fragment set:html={main} />
</Base>
