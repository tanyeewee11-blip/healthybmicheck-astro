---
import Base from '../layouts/Base.astro';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Health Guides — HealthyBMICheck.com",
  "description": "Free, evidence-based health guides on BMI, weight loss, calories, nutrition, and hydration. Written for adults, seniors, and Asian populations.",
  "url": "https://healthybmicheck.com/guides.html",
  "publisher": { "@type": "Organization", "name": "HealthyBMICheck.com", "url": "https://healthybmicheck.com" }
});

const breadcrumbJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthybmicheck.com/" },
    { "@type": "ListItem", "position": 2, "name": "Health Guides", "item": "https://healthybmicheck.com/guides.html" }
  ]
});

const guides = [
  {
    category: "BMI",
    icon: "⚖️",
    articles: [
      { title: "What Is BMI?", desc: "A complete explanation of Body Mass Index — how it's calculated, what it measures, and its limitations.", href: "what-is-bmi.html", read: "5 min" },
      { title: "BMI vs Body Fat %", desc: "Which metric matters more for your health? When BMI misleads and when body fat % is essential.", href: "bmi-vs-body-fat.html", read: "6 min" },
      { title: "BMI Chart by Age", desc: "Healthy BMI ranges and age-specific health guidance for adults aged 20–65, for both men and women.", href: "bmi-chart-by-age.html", read: "6 min" },
      { title: "BMI Chart for Men Over 60", desc: "Healthy weight ranges, average BMI at this age, and what the numbers mean for older men's health.", href: "bmi-chart-men-over-60.html", read: "5 min" },
      { title: "BMI for Asian Women", desc: "Why standard BMI ranges don't apply to Asian women — and what thresholds to use instead.", href: "healthy-bmi-asian-women.html", read: "5 min" },
      { title: "BMI and Calorie Calculator — How They Work Together", desc: "BMI tells you where you are. A calorie calculator tells you how to get to your goal.", href: "bmi-and-calorie-calculator.html", read: "5 min" },
      { title: "Normal BMI for Women", desc: "Healthy BMI ranges for women by age, how female body composition affects BMI, and what to do if you're outside the normal range.", href: "normal-bmi-for-women.html", read: "7 min" },
      { title: "BMI and Diabetes Risk", desc: "At what BMI does diabetes risk rise? Why Asian populations are at higher risk at lower BMI values, and how much weight loss reduces your risk.", href: "bmi-and-diabetes-risk.html", read: "7 min" },
    ]
  },
  {
    category: "Weight Loss",
    icon: "📉",
    articles: [
      { title: "How to Lose 5kg Safely", desc: "A realistic, science-based plan — the right calorie deficit, protein targets, and timeline to expect.", href: "how-to-lose-5kg.html", read: "7 min" },
      { title: "Average Weight for a 55-Year-Old Woman", desc: "Average weight by height, healthy weight ranges, and what affects weight in your mid-50s.", href: "average-weight-55-year-old-woman.html", read: "5 min" },
      { title: "Healthy Weight for Seniors", desc: "BMI ranges, healthy weight by height, and what actually matters for men and women over 60.", href: "healthy-weight-for-seniors.html", read: "6 min" },
      { title: "How to Lower Your BMI", desc: "Proven, science-based methods that actually work — calorie deficit, protein targets, the right exercise, and what to avoid.", href: "how-to-lower-bmi.html", read: "8 min" },
      { title: "Intermittent Fasting for Weight Loss", desc: "Does intermittent fasting actually work? The honest science on 16:8, 5:2, and which protocol suits you best.", href: "intermittent-fasting-for-weight-loss.html", read: "8 min" },
    ]
  },
  {
    category: "Nutrition & Exercise",
    icon: "🥗",
    articles: [
      { title: "What to Eat to Lose Weight", desc: "No fad diets. The evidence-based foods that make a calorie deficit easier to sustain.", href: "what-to-eat-to-lose-weight.html", read: "7 min" },
      { title: "Cardio vs Weights for Fat Loss", desc: "Which burns more fat — cardio or resistance training? The science-based answer might surprise you.", href: "cardio-vs-weights.html", read: "6 min" },
      { title: "High-Protein Diet Plan for Weight Loss", desc: "Exact protein targets by body weight, the 20 best high-protein foods, and a 3-day meal plan to hit your numbers.", href: "high-protein-diet-plan.html", read: "9 min" },
    ]
  },
  {
    category: "Hydration",
    icon: "💧",
    articles: [
      { title: "How Much Water Per Day by Weight", desc: "The weight-based formula for daily water intake — with a full chart and adjustments for climate and exercise.", href: "how-much-water-per-day-by-weight.html", read: "5 min" },
    ]
  },
];
---

<Base
  schemaJson={schemaJson}
  breadcrumbJson={breadcrumbJson}
  title="Health Guides — BMI, Weight Loss, Calories & More | HealthyBMICheck"
  description="Free, evidence-based health guides on BMI, weight loss, calories, nutrition, and hydration. Written for adults, seniors, and Asian populations."
  canonical="https://healthybmicheck.com/guides.html"
>

<style>
  .guides-hero { text-align: center; padding: 48px 24px 32px; max-width: 640px; margin: 0 auto; }
  .guides-hero h1 { font-size: 2.25rem; font-weight: 500; line-height: 1.2; margin-bottom: 14px; }
  .guides-hero h1 em { font-style: italic; color: var(--accent); font-family: 'DM Serif Display', serif; }
  .guides-hero p { font-size: 1rem; color: var(--ink2); line-height: 1.7; }

  .guides-wrap { max-width: 800px; margin: 0 auto; padding: 0 24px 64px; }

  .guide-category { margin-bottom: 40px; }
  .cat-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1.5px solid var(--border); }
  .cat-icon { font-size: 1.2rem; }
  .cat-title { font-size: 1rem; font-weight: 600; color: var(--ink); letter-spacing: .01em; }

  .articles-list { display: flex; flex-direction: column; gap: 10px; }
  .article-row { display: flex; align-items: flex-start; gap: 16px; padding: 14px 18px; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .15s; }
  .article-row:hover { border-color: var(--accent); box-shadow: 0 2px 12px rgba(45,106,79,.08); }
  .article-row-text { flex: 1; }
  .article-row-title { font-size: .95rem; font-weight: 600; color: var(--ink); margin-bottom: 4px; line-height: 1.3; }
  .article-row-desc { font-size: .83rem; color: var(--ink2); line-height: 1.6; }
  .article-row-meta { display: flex; align-items: center; gap: 6px; margin-top: 6px; }
  .article-row-read { font-size: .75rem; color: var(--ink3); }
  .article-row-arrow { flex-shrink: 0; color: var(--accent); margin-top: 2px; }

  @media (max-width: 600px) {
    .guides-hero h1 { font-size: 1.65rem; }
    .article-row { padding: 12px 14px; }
  }
</style>

<div class="guides-hero">
  <p class="section-label">Health Guides</p>
  <h1>Learn & <em>Understand</em></h1>
  <p>Evidence-based guides on BMI, weight, nutrition, and hydration — no fads, no fluff.</p>
</div>

<div class="guides-wrap">
  {guides.map(group => (
    <div class="guide-category">
      <div class="cat-header">
        <span class="cat-icon">{group.icon}</span>
        <span class="cat-title">{group.category}</span>
      </div>
      <div class="articles-list">
        {group.articles.map(article => (
          <a class="article-row" href={article.href}>
            <div class="article-row-text">
              <div class="article-row-title">{article.title}</div>
              <div class="article-row-desc">{article.desc}</div>
              <div class="article-row-meta">
                <span class="article-row-read">📖 {article.read} read</span>
              </div>
            </div>
            <div class="article-row-arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}
</div>

</Base>
