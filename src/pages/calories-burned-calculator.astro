        </optgroup>
        <optgroup label="🏅 Sports">
          <option value="7.0">Basketball</option>
          <option value="7.0">Football / soccer</option>
          <option value="6.0">Tennis — singles</option>
          <option value="4.5">Tennis — doubles</option>
          <option value="5.5">Badminton</option>
          <option value="8.0">Squash</option>
          <option value="4.0">Golf (walking)</option>
          <option value="7.0">Volleyball — competitive</option>
          <option value="5.0">Dancing — moderate</option>
          <option value="8.0">Dancing — vigorous</option>
          <option value="4.0">Hiking — moderate</option>
          <option value="6.0">Hiking — steep terrain</option>
        </optgroup>
        <optgroup label="🏠 Daily Activities">
          <option value="3.5">Housework — general</option>
          <option value="4.5">Gardening</option>
