  <!-- Result -->
  <div class="result-card" id="result-card">
    <div style="text-align:center;padding:20px;">
      <div id="result-num" style="font-size:2.8rem;font-weight:500;color:var(--accent);font-family:'DM Serif Display',serif;">—</div>
