          <option value="8.0">Running — slow (8 km/h)</option>
          <option value="9.8">Running — moderate (10 km/h)</option>
          <option value="11.0">Running — fast (12 km/h)</option>
          <option value="13.0">Running — very fast (14 km/h+)</option>
          <option value="9.0">Treadmill running</option>
          <option value="9.5">Trail running</option>
        </optgroup>
        <optgroup label="🚴 Cycling">
          <option value="4.0">Cycling — light (< 16 km/h)</option>
