      <a href="/how-many-steps-per-day">How Many Steps Per Day?</a>
      <a href="/how-to-lose-weight-fast-safely">How to Lose Weight Fast Safely</a>
    </div>
  </div>

</div>

<div class="cta-block" style="margin-top:-16px">
    <div class="cta-inner">
  
  <p style="font-size:.8rem;font-weight:600;color:#7EC8A4;text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;">Next step</p>
  <h2 style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:#fff;margin-bottom:8px;line-height:1.2;">Turn your burn into a weight loss plan</h2>
  <p style="font-size:.9rem;color:rgba(255,255,255,.6);margin-bottom:20px;max-width:400px;margin-left:auto;margin-right:auto;">Calculate how many calories you need each day and set a realistic deficit.</p>
  <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">
    <a href="/calorie-calculator" style="display:inline-flex;align-items:center;gap:8px;background:#2D6A4F;color:#fff;text-decoration:none;border-radius:100px;padding:12px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;">🔥 Daily Calorie Needs →</a>
    <a href="/calorie-deficit-calculator" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);color:#fff;text-decoration:none;border-radius:100px;padding:11px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;border:1.5px solid rgba(255,255,255,.4);">📉 Calorie Deficit →</a>
    <a href="/bmr-calculator" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);color:#fff;text-decoration:none;border-radius:100px;padding:11px 22px;font-size:.9rem;font-weight:500;font-family:'DM Sans',sans-serif;border:1.5px solid rgba(255,255,255,.4);">⚡ BMR Calculator →</a>
  </div>

    </div>
  </div>
<script is:inline>
let unit = 'metric';

function setUnit(u) {
  unit = u;
  document.querySelectorAll('.unit-toggle button').forEach((b,i) => b.classList.toggle('active', (u==='metric'&&i===0)||(u==='imperial'&&i===1)));
  document.getElementById('kg-wrap').style.display = u==='metric' ? '' : 'none';
  document.getElementById('lb-wrap').style.display = u==='imperial' ? '' : 'none';
}

function calculate() {
  let weightKg;
  if (unit === 'metric') {
    weightKg = parseFloat(document.getElementById('weight-kg').value);
  } else {
    const lb = parseFloat(document.getElementById('weight-lb').value);
    weightKg = lb * 0.453592;
  }
  const duration = parseFloat(document.getElementById('duration-min').value);
  const met = parseFloat(document.getElementById('activity-select').value);
  const activityName = document.getElementById('activity-select').options[document.getElementById('activity-select').selectedIndex].text;

  if (!weightKg || !duration || weightKg < 20 || duration < 1) {
    alert('Please fill in all fields with valid values.');
    return;
  }

  const calories = Math.round(met * weightKg * (duration / 60));

  document.getElementById('result-num').textContent = calories.toLocaleString();
  document.getElementById('result-label').textContent = `calories burned — ${activityName} for ${duration} min`;

  // Comparison context
  const comparisons = [
    { label: 'Equivalent to', value: `${(calories / 4).toFixed(0)} g of carbohydrates` },
    { label: 'Same as burning', value: `${(calories / 7700 * 1000).toFixed(1)} g of body fat` },
    { label: 'To cancel out', value: `a ${calories < 200 ? 'small snack (~150 kcal)' : calories < 400 ? 'medium meal (~350 kcal)' : 'large meal (~500+ kcal)'}` },
    { label: 'Weekly burn', value: `${(calories * 7).toLocaleString()} kcal if done daily` },
  ];

  document.getElementById('comparison-rows').innerHTML = comparisons.map(c => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:var(--surface);border-radius:8px;font-size:.85rem;">
      <span style="color:var(--ink3);">${c.label}</span>
      <strong style="color:var(--ink1);margin-left:12px;text-align:right;">${c.value}</strong>
    </div>
  `).join('');

  document.getElementById('comparison-section').style.display = '';
  document.getElementById('result-card').classList.add('visible');
  document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function toggleFaq(btn) {
  btn.classList.toggle('open');
  btn.nextElementSibling.classList.toggle('open');
}
</script>

</Base>
