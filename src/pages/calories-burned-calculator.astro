          <option value="10.0">Cycling — vigorous (25–30 km/h)</option>
          <option value="8.5">Stationary bike — moderate</option>
          <option value="11.0">Stationary bike — vigorous</option>
          <option value="8.0">Spinning class</option>
        </optgroup>
        <optgroup label="🏊 Swimming">
          <option value="5.8">Swimming — light</option>
          <option value="7.0">Swimming — freestyle moderate</option>
