          <option value="8.0">Swimming — breaststroke</option>
        </optgroup>
        <optgroup label="💪 Gym & Fitness">
          <option value="3.5">Weight training — light</option>
          <option value="5.0">Weight training — vigorous</option>
          <option value="7.0">Circuit training</option>
          <option value="8.0">HIIT</option>
          <option value="6.0">Aerobics class</option>
          <option value="4.0">Yoga — hatha</option>
          <option value="6.0">Yoga — power / vinyasa</option>
          <option value="10.0">Jump rope</option>
          <option value="7.0">Rowing machine — moderate</option>
          <option value="10.0">Rowing machine — vigorous</option>
