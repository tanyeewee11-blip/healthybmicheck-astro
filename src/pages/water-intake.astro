      <div class="info-box"><div class="ilabel">In fl oz (US)</div><div class="ivalue" id="oz-val">—</div></div>
      <div class="info-box"><div class="ilabel">250ml glasses</div><div class="ivalue" id="glasses-val">—</div></div>
      <div class="info-box"><div class="ilabel">500ml bottles</div><div class="ivalue" id="bottles-val">—</div></div>
    </div>
    <div class="tip-box" id="tip-box"></div>
  </div>

  <div class="table-section">
    <h2 class="section-title">General Daily Water Guidelines</h2>
    <p class="section-sub">Based on weight and activity level for adults in a warm climate.</p>
    <table>
      <thead><tr><th>Body Weight</th><th>Sedentary</th><th>Moderately Active</th><th>Very Active</th></tr></thead>
      <tbody>
        <tr><td>50 kg (110 lb)</td><td>1.5 L</td><td>1.9 L</td><td>2.3 L</td></tr>
        <tr><td>60 kg (132 lb)</td><td>1.8 L</td><td>2.2 L</td><td>2.6 L</td></tr>
        <tr><td>70 kg (154 lb)</td><td>2.1 L</td><td>2.5 L</td><td>3.0 L</td></tr>
        <tr><td>80 kg (176 lb)</td><td>2.4 L</td><td>2.9 L</td><td>3.4 L</td></tr>
        <tr><td>90 kg (198 lb)</td><td>2.7 L</td><td>3.2 L</td><td>3.8 L</td></tr>
        <tr><td>100 kg (220 lb)</td><td>3.0 L</td><td>3.6 L</td><td>4.2 L</td></tr>
      </tbody>
    </table>
  </div>

  
<div class="card" class="table-scroll">
  <p class="verdict-label">Urine colour hydration guide</p>
