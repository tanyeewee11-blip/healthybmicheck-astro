<script is:inline>
  let unit = 'metric';
  function setUnit(u) {
    unit = u;
    document.querySelectorAll('.unit-toggle button').forEach((b,i)=>b.classList.toggle('active',(u==='metric'&&i===0)||(u==='imperial'&&i===1)));
    document.getElementById('metric-w').style.display = u==='metric'?'':'none';
    document.getElementById('imperial-w').style.display = u==='imperial'?'':'none';
  }
  function calculate() {
    let weightKg;
    if(unit==='metric') weightKg = parseFloat(document.getElementById('weight-kg').value);
    else weightKg = parseFloat(document.getElementById('weight-lb').value) * 0.453592;
    if(!weightKg||weightKg<10) { alert('Please enter a valid weight.'); return; }
    const activity = parseFloat(document.getElementById('activity').value);
    const climate  = parseFloat(document.getElementById('climate').value);
    // Base: 35ml per kg, adjusted for activity and climate
    const baseMl = weightKg * 35;
    const actMl  = weightKg * activity * 10;
    const climMl = weightKg * climate * 10;
    const totalMl = Math.round((baseMl + actMl + climMl) / 50) * 50;
    const totalL  = (totalMl / 1000).toFixed(1);
    const totalOz = (totalMl / 29.5735).toFixed(0);
    const glasses = Math.ceil(totalMl / 250);
    const bottles = Math.ceil(totalMl / 500);
    document.getElementById('water-main').textContent = totalL + ' L';
    document.getElementById('ml-val').textContent = totalMl.toLocaleString() + ' ml';
    document.getElementById('oz-val').textContent = totalOz + ' fl oz';
    document.getElementById('glasses-val').textContent = glasses + ' glasses';
    document.getElementById('bottles-val').textContent = bottles + ' bottles';
    // Cups visual
    const cupsRow = document.getElementById('cups-row');
    cupsRow.innerHTML = '';
    for(let i=0;i<glasses;i++) {
      const cup = document.createElement('span');
      cup.className = 'cup';
      cup.textContent = '🥛';
      cupsRow.appendChild(cup);
    }
    // Tip
    const tips = [
      'Start your day with a glass of water before coffee or tea — it helps kickstart your metabolism.',
      'Carry a reusable water bottle and aim to refill it based on your bottle count above.',
      'Set hourly reminders on your phone to drink water throughout the day.',
      'Eat water-rich foods like cucumber, watermelon, and leafy greens to supplement your intake.'
    ];
    document.getElementById('tip-box').textContent = tips[Math.floor(Math.random()*tips.length)];
    document.getElementById('result-card').classList.add('visible');
    
    document.getElementById('result-card').scrollIntoView({behavior:'smooth',block:'nearest'});
  }
  function toggleFaq(btn) { btn.nextElementSibling.classList.toggle('open'); btn.classList.toggle('open'); }
  document.addEventListener('keydown', e=>{ if(e.key==='Enter') calculate(); });
</script>


