---
import Base from '../layouts/Base.astro';
const schemaJson = JSON.stringify({"@context":"https://schema.org","@graph":[{"@type":"AboutPage","name":"About HealthyBMICheck.com","url":"https://healthybmicheck.com/about.html","publisher":{"@type":"Organization","name":"HealthyBMICheck.com","url":"https://healthybmicheck.com"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is HealthyBMICheck.com free to use?","acceptedAnswer":{"@type":"Answer","text":"Yes - all calculators, charts, and guides are completely free with no registration required. Supported by non-intrusive advertising. We do not sell user data."}},{"@type":"Question","name":"How accurate are the calculators?","acceptedAnswer":{"@type":"Answer","text":"We use validated, peer-reviewed formulas standard in clinical settings. Results are population estimates - use as a starting point, not a clinical diagnosis."}},{"@type":"Question","name":"Can I use this for medical decisions?","acceptedAnswer":{"@type":"Answer","text":"No - content is for informational purposes only. Not a substitute for professional medical advice. Always consult a qualified healthcare provider."}},{"@type":"Question","name":"Do you collect my health data?","acceptedAnswer":{"@type":"Answer","text":"No. All calculations run in your browser. Nothing you enter is sent to our servers, stored, or shared."}},{"@type":"Question","name":"What is the Asian BMI standard?","acceptedAnswer":{"@type":"Answer","text":"The WHO recommends lower BMI thresholds for Asian adults - overweight at BMI 23 rather than 25 - because Asian populations develop metabolic risks at lower BMI values."}}]}]});
const breadcrumbJson = JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://healthybmicheck.com/"},{"@type":"ListItem","position":2,"name":"About","item":"https://healthybmicheck.com/about.html"}]});
---
<Base
  schemaJson={schemaJson}
  breadcrumbJson={breadcrumbJson}
  title="About HealthyBMICheck.com — Free Health Calculators"
  description="HealthyBMICheck.com offers 13 free, evidence-based health calculators — BMI, calories, macros, body fat and more. No sign-up, no data collection, instant results."
  canonical="https://healthybmicheck.com/about.html"
>

<style>
  .ab { max-width: 720px; margin: 0 auto; padding: 0 20px; }
  .ab-hero { text-align: center; padding: 36px 0 28px; }
  .ab-hero h1 { font-size: 2rem; font-weight: 500; color: var(--ink1); line-height: 1.25; margin-bottom: 12px; }
  .ab-hero h1 em { font-style: italic; color: var(--accent); font-family: 'DM Serif Display', serif; }
  .ab-hero p { font-size: .95rem; color: var(--ink3); line-height: 1.7; max-width: 480px; margin: 0 auto 18px; }
  .ab-chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .ab-chip { font-size: .78rem; padding: 5px 12px; border-radius: 100px; border: 1px solid var(--border); color: var(--ink3); display: inline-flex; align-items: center; gap: 6px; }

  .ab-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 32px; }
  .ab-stat { background: var(--surface); border-radius: 12px; padding: 18px 12px; text-align: center; border: 1px solid var(--border); }
  .ab-stat-num { font-size: 1.75rem; font-weight: 500; color: var(--accent); font-family: 'DM Serif Display', serif; }
  .ab-stat-lbl { font-size: .75rem; color: var(--ink3); margin-top: 4px; line-height: 1.3; }

  .ab-div { height: 1px; background: var(--border); margin: 0 0 28px; }
  .ab-lbl { font-size: .72rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--ink3); margin-bottom: 14px; }

  .ab-hl { background: var(--accent-light); border-radius: 14px; padding: 18px 20px; margin-bottom: 10px; }
  .ab-hl p { font-size: .9rem; color: var(--ink2); line-height: 1.75; margin: 0; }
  .ab-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px 20px; margin-bottom: 10px; }
  .ab-card p { font-size: .9rem; color: var(--ink2); line-height: 1.75; margin: 0 0 10px; }
  .ab-card p:last-child { margin-bottom: 0; }

  .ab-pgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 28px; }
  .ab-pc { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 16px; }
  .ab-pc-icon { width: 34px; height: 34px; border-radius: 9px; background: var(--bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
  .ab-pc-icon svg { width: 17px; height: 17px; color: var(--accent); }
  .ab-pc-title { font-size: .875rem; font-weight: 500; color: var(--ink1); margin-bottom: 5px; }
  .ab-pc-desc { font-size: .8rem; color: var(--ink3); line-height: 1.6; }

  .ab-team-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px 20px; margin-bottom: 10px; }
  .ab-member { display: flex; gap: 12px; align-items: flex-start; padding-bottom: 14px; margin-bottom: 14px; border-bottom: 1px solid var(--border); }
  .ab-member:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none; }
  .ab-av { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 500; flex-shrink: 0; }
  .av-teal { background: #9FE1CB; color: #085041; }
  .av-blue { background: #B5D4F4; color: #0C447C; }
  .ab-mname { font-size: .9rem; font-weight: 500; color: var(--ink1); }
  .ab-mrole { font-size: .8rem; color: var(--ink3); margin-top: 3px; line-height: 1.5; }

  .ab-steps { display: flex; flex-direction: column; gap: 10px; }
  .ab-step { display: flex; gap: 12px; align-items: flex-start; }
  .ab-snum { width: 22px; height: 22px; border-radius: 50%; background: var(--accent); color: #fff; font-size: .72rem; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
  .ab-stxt { font-size: .875rem; color: var(--ink2); line-height: 1.65; }

  .ab-srcs { display: flex; flex-direction: column; gap: 8px; }
  .ab-src { display: flex; gap: 9px; align-items: center; font-size: .875rem; color: var(--ink2); }
  .ab-src svg { width: 14px; height: 14px; color: var(--accent); flex-shrink: 0; }

  .ab-calcs { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 28px; }
  .ab-calc { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-bottom: 1px solid var(--border); background: var(--surface); text-decoration: none; color: inherit; transition: background .15s; }
  .ab-calc:last-child { border-bottom: none; }
  .ab-calc:hover { background: var(--bg); }
  .ab-cicon { width: 32px; height: 32px; border-radius: 9px; background: var(--bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ab-cicon svg { width: 16px; height: 16px; color: var(--accent); }
  .ab-cname { font-size: .875rem; font-weight: 500; color: var(--ink1); flex: 1; }
  .ab-cformula { font-size: .75rem; color: var(--ink3); }
  .ab-carrow svg { width: 15px; height: 15px; color: var(--ink3); }

  .ab-tbl { width: 100%; border-collapse: collapse; font-size: .85rem; }
  .ab-tbl th { text-align: left; font-weight: 500; font-size: .75rem; color: var(--ink3); padding: 10px 14px; border-bottom: 2px solid var(--border); }
  .ab-tbl td { padding: 10px 14px; border-bottom: 1px solid var(--border); color: var(--ink2); vertical-align: top; }
  .ab-tbl tr:last-child td { border-bottom: none; }
  .ab-tbl td:first-child a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .ab-tbl tr:nth-child(odd) { background: var(--surface); }

  .ab-faqs { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 28px; }
  .ab-fq { border-bottom: 1px solid var(--border); }
  .ab-fq:last-child { border-bottom: none; }
  .ab-fqbtn { width: 100%; padding: 15px 18px; background: var(--surface); border: none; text-align: left; font-size: .875rem; font-weight: 500; color: var(--ink1); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; font-family: inherit; transition: background .15s; }
  .ab-fqbtn:hover { background: var(--bg); }
  .ab-fqbtn svg { width: 16px; height: 16px; color: var(--ink3); flex-shrink: 0; transition: transform .2s; }
  .ab-fq.open .ab-fqbtn svg { transform: rotate(180deg); }
  .ab-fqbody { display: none; padding: 0 18px 16px; font-size: .875rem; color: var(--ink2); line-height: 1.75; background: var(--surface); }
  .ab-fq.open .ab-fqbody { display: block; }

  .ab-disclaimer { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; display: flex; gap: 10px; align-items: flex-start; margin-bottom: 28px; }
  .ab-disclaimer svg { width: 17px; height: 17px; color: #BA7517; flex-shrink: 0; margin-top: 2px; }
  .ab-disclaimer p { font-size: .82rem; color: var(--ink3); line-height: 1.65; margin: 0; }

  @media (max-width: 480px) {
    .ab-hero h1 { font-size: 1.6rem; }
    .ab-pgrid { grid-template-columns: 1fr; }
    .ab-tbl td:last-child { display: none; }
  }
</style>

<div class="ab">

  <!-- Breadcrumb -->
  <div style="font-size:.78rem;color:var(--ink3);padding:16px 0 0;">
    <a href="index.html" style="color:var(--ink3);text-decoration:none;">Home</a> &rsaquo; About
  </div>

  <!-- Hero -->
  <div class="ab-hero">
    <h1>Free health tools,<br><em>built on real science</em></h1>
    <p>Evidence-based calculators &mdash; no sign-up, no data collection, no cost. Built by people who care about getting the numbers right.</p>
    <div class="ab-chips">
      <span class="ab-chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
        Peer-reviewed formulas
      </span>
      <span class="ab-chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        No data collected
      </span>
      <span class="ab-chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Instant results
      </span>
      <span class="ab-chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Free forever
      </span>
    </div>
  </div>

  <!-- Stats -->
  <div class="ab-stats">
    <div class="ab-stat"><div class="ab-stat-num">13</div><div class="ab-stat-lbl">Free calculators</div></div>
    <div class="ab-stat"><div class="ab-stat-num">0</div><div class="ab-stat-lbl">Data collected</div></div>
    <div class="ab-stat"><div class="ab-stat-num">100%</div><div class="ab-stat-lbl">Browser-side</div></div>
  </div>

  <div class="ab-div"></div>

  <!-- Why we built this -->
  <div style="margin-bottom:28px;">
    <div class="ab-lbl">Why we built this</div>
    <div class="ab-hl">
      <p>Too many online health calculators use outdated formulas, bury results behind sign-up walls, or surround sensitive health information with intrusive ads. We wanted to do better.</p>
    </div>
    <div class="ab-card">
      <p>HealthyBMICheck.com is an independent project. We&rsquo;re not affiliated with any hospital, pharmaceutical company, supplement brand, or health insurer. We have no financial interest in the results our calculators produce &mdash; only in making them as accurate and useful as possible.</p>
      <p>Every tool on this site uses a formula from peer-reviewed research or established clinical guidelines. We cite our sources, explain the limitations, and tell you what to do with your result.</p>
    </div>
  </div>

  <div class="ab-div"></div>

  <!-- Principles -->
  <div style="margin-bottom:28px;">
    <div class="ab-lbl">Our principles</div>
    <div class="ab-pgrid">
      <div class="ab-pc">
        <div class="ab-pc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg></div>
        <div class="ab-pc-title">Evidence-based</div>
        <div class="ab-pc-desc">Every formula from peer-reviewed research. Sources cited on every page.</div>
      </div>
      <div class="ab-pc">
        <div class="ab-pc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <div class="ab-pc-title">No data collected</div>
        <div class="ab-pc-desc">All calculations run in your browser. Nothing leaves your device.</div>
      </div>
      <div class="ab-pc">
        <div class="ab-pc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
        <div class="ab-pc-title">No friction</div>
        <div class="ab-pc-desc">No sign-up, no paywall. Enter your numbers and get results instantly.</div>
      </div>
      <div class="ab-pc">
        <div class="ab-pc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
        <div class="ab-pc-title">Explained</div>
        <div class="ab-pc-desc">We tell you what your result means and what to do next.</div>
      </div>
    </div>
  </div>

  <div class="ab-div"></div>

  <!-- Content team -->
  <div style="margin-bottom:28px;">
    <div class="ab-lbl">Editorial standards &amp; content team</div>
    <div class="ab-card" style="margin-bottom:10px;">
      <p>All content is researched, written, and reviewed by individuals with backgrounds in health sciences, nutrition, and clinical dietetics. Every article and calculator is checked for accuracy against current clinical guidelines before publication and updated regularly.</p>
    </div>
    <div class="ab-team-card">
      <div class="ab-member">
        <div class="ab-av av-teal">SM</div>
        <div>
          <div class="ab-mname">Sarah Mitchell, BSc Nutrition &amp; Dietetics</div>
          <div class="ab-mrole">Lead health writer &nbsp;&middot;&nbsp; 8 years clinical nutrition communication &nbsp;&middot;&nbsp; formerly NHS dietetics support team</div>
        </div>
      </div>
      <div class="ab-member">
        <div class="ab-av av-blue">JO</div>
        <div>
          <div class="ab-mname">James Okafor, MSc Public Health</div>
          <div class="ab-mrole">Research &amp; fact-checking &nbsp;&middot;&nbsp; epidemiology and health metrics</div>
        </div>
      </div>
    </div>
    <div class="ab-card" style="margin-top:10px;">
      <div class="ab-lbl" style="margin-bottom:12px;">Review process</div>
      <div class="ab-steps">
        <div class="ab-step"><div class="ab-snum">1</div><div class="ab-stxt">All claims sourced to peer-reviewed literature or clinical guidelines before publication</div></div>
        <div class="ab-step"><div class="ab-snum">2</div><div class="ab-stxt">Calculator formulas verified against original research (Mifflin-St Jeor, Devine, Katch-McArdle, etc.)</div></div>
        <div class="ab-step"><div class="ab-snum">3</div><div class="ab-stxt">Content reviewed and updated when guidelines change &mdash; each page shows its last-updated date</div></div>
        <div class="ab-step"><div class="ab-snum">4</div><div class="ab-stxt">Medical disclaimer on every page; we do not provide personalised medical advice</div></div>
      </div>
    </div>
    <div class="ab-card" style="margin-top:10px;">
      <div class="ab-lbl" style="margin-bottom:12px;">Our sources include</div>
      <div class="ab-srcs">
        <div class="ab-src"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>World Health Organization (WHO)</div>
        <div class="ab-src"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Centers for Disease Control and Prevention (CDC)</div>
        <div class="ab-src"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>National Institutes of Health (NIH)</div>
        <div class="ab-src"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>The Lancet, JAMA, American Journal of Clinical Nutrition</div>
      </div>
    </div>
  </div>

  <div class="ab-div"></div>

  <!-- Calculators list -->
  <div style="margin-bottom:28px;">
    <div class="ab-lbl">Our 13 free calculators</div>
    <div class="ab-calcs">
      <a class="ab-calc" href="bmi-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-4M8 18H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-4M12 18v4"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></div><span class="ab-cname">BMI Calculator</span><span class="ab-cformula">WHO formula</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="calorie-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg></div><span class="ab-cname">Calorie Calculator</span><span class="ab-cformula">Mifflin-St Jeor</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="bmr-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div><span class="ab-cname">BMR Calculator</span><span class="ab-cformula">Mifflin + Harris-Benedict</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="calories-burned-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><span class="ab-cname">Calories Burned</span><span class="ab-cformula">MET method</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="protein-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg></div><span class="ab-cname">Protein Calculator</span><span class="ab-cformula">g/kg by goal</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="calorie-deficit-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div><span class="ab-cname">Calorie Deficit</span><span class="ab-cformula">Weight loss timeline</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="macro-calculator.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg></div><span class="ab-cname">Macro Calculator</span><span class="ab-cformula">Protein &middot; carbs &middot; fat</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
      <a class="ab-calc" href="ideal-weight.html"><div class="ab-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg></div><span class="ab-cname">Ideal Weight</span><span class="ab-cformula">4 formula average</span><span class="ab-carrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span></a>
