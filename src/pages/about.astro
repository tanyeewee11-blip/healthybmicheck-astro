---
import Base from '../layouts/Base.astro';
const main = "<!-- Hero -->\n<div class=\"about-hero\">\n  <h1>Free health tools,<br><em>built on real science</em></h1>\n  <p>HealthyBMICheck.com gives everyone access to accurate, evidence-based health calculators — no sign-up, no data collection, no cost.</p>\n  <div class=\"trust-chips\">\n    <span class=\"trust-chip\">🔬 Peer-reviewed formulas</span>\n    <span class=\"trust-chip\">🔒 No data collected</span>\n    <span class=\"trust-chip\">⚡ Instant results</span>\n    <span class=\"trust-chip\">🌏 Free forever</span>\n  </div>\n</div>\n\n<div class=\"container\">\n\n  <!-- Stats -->\n  <div class=\"stats-row\">\n    <div class=\"stat-box\">\n      <div class=\"num\">11</div>\n      <div class=\"lbl\">Free calculators</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"num\">0</div>\n      <div class=\"lbl\">Data collected</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"num\">100%</div>\n      <div class=\"lbl\">Browser-side calculations</div>\n    </div>\n  </div>\n\n  <!-- Mission -->\n  <div class=\"mission-block\">\n    <h2 style=\"font-family:'DM Serif Display',serif;font-size:1.4rem;margin-bottom:14px;\">Why we built this</h2>\n    <p>Too many online health calculators use outdated formulas, bury results behind sign-up walls, or show intrusive advertising around sensitive health information. We wanted to do better.</p>\n    <p>HealthyBMICheck.com is an independent project. We're not affiliated with any hospital, pharmaceutical company, supplement brand, or health insurer. We have no financial interest in the results our calculators produce — only in making them as accurate and useful as possible.</p>\n    <p>Every tool on this site uses a formula from peer-reviewed research or established clinical guidelines. We cite our sources, explain the limitations, and tell you what to do with your result.</p>\n  </div>\n\n  <!-- Editorial Standards & E-E-A-T -->\n  <div class=\"mission-block\" style=\"border-left: 4px solid var(--accent); margin-bottom: 20px;\">\n    <h2 style=\"font-family:'DM Serif Display',serif;font-size:1.4rem;margin-bottom:14px;\">Editorial Standards & Content Review</h2>\n    <p>All content on HealthyBMICheck.com is researched and written by individuals with backgrounds in health sciences, nutrition, and data analysis. Our articles and calculator explanations are reviewed for accuracy against current clinical guidelines before publication.</p>\n    <p><strong>Our content is based on:</strong></p>\n    <ul style=\"margin: 8px 0 12px 20px; color: var(--ink2); font-size: .95rem; line-height: 1.8;\">\n      <li>World Health Organization (WHO) clinical guidelines and fact sheets</li>\n      <li>Centers for Disease Control and Prevention (CDC) recommendations</li>\n      <li>National Institutes of Health (NIH) published research</li>\n      <li>Peer-reviewed journals including <em>The Lancet</em>, <em>Nutrition Today</em>, and <em>JAMA</em></li>\n    </ul>\n    <p>We review and update our content regularly to reflect the latest evidence. If you believe any information on this site is inaccurate or outdated, please <a href=\"contact.html\" style=\"color:var(--accent);\">contact us</a> — we take accuracy seriously.</p>\n    <p style=\"margin-bottom:0;\"><strong>Medical disclaimer:</strong> Content on this site is for informational and educational purposes only. It is not a substitute for professional medical advice, diagnosis, or treatment. Always consult a qualified healthcare provider before making health decisions.</p>\n  </div>\n\n    <!-- Principles -->\n  <h2 class=\"section-title\">Our principles</h2>\n  <p class=\"section-sub\">Four commitments we hold ourselves to on every page.</p>\n  <div class=\"principle-grid\">\n    <div class=\"principle-card\">\n      <div class=\"picon\">🔬</div>\n      <h3>Evidence-based formulas</h3>\n      <p>Every calculator uses a formula from peer-reviewed research or established clinical guidelines. We cite our sources on every page.</p>\n    </div>\n    <div class=\"principle-card\">\n      <div class=\"picon\">🔒</div>\n      <h3>No data collection</h3>\n      <p>All calculations run entirely in your browser. Nothing you enter is sent to our servers, stored, or shared with anyone.</p>\n    </div>\n    <div class=\"principle-card\">\n      <div class=\"picon\">⚡</div>\n      <h3>Instant, no friction</h3>\n      <p>No sign-up, no email confirmation, no paywall. Enter your numbers and get your result in under a second.</p>\n    </div>\n    <div class=\"principle-card\">\n      <div class=\"picon\">📖</div>\n      <h3>Explained, not just calculated</h3>\n      <p>We tell you what your result means, what its limitations are, and what to do next — not just a bare number.</p>\n    </div>\n  </div>\n\n  <!-- Tools -->\n  <h2 class=\"section-title\">Our calculators</h2>\n  <p class=\"section-sub\">11 free tools covering the most important health metrics.</p>\n  <div class=\"tools-grid\">\n    <a href=\"bmi-calculator.html\" class=\"tool-item\">\n      <div class=\"t-icon\">⚖️</div>\n      <div class=\"t-name\">BMI Calculator</div>\n      <div class=\"t-desc\">Body Mass Index</div>\n    </a>\n    <a href=\"asian-bmi-calculator.html\" class=\"tool-item\">\n      <div class=\"t-icon\">🌏</div>\n      <div class=\"t-name\">Asian BMI</div>\n      <div class=\"t-desc\">Asian-specific thresholds</div>\n    </a>\n    <a href=\"bmi-calculator-kids.html\" class=\"tool-item\">\n      <div class=\"t-icon\">👶</div>\n      <div class=\"t-name\">Kids BMI</div>\n      <div class=\"t-desc\">CDC percentile method</div>\n    </a>\n    <a href=\"calorie-calculator.html\" class=\"tool-item\">\n      <div class=\"t-icon\">🔥</div>\n      <div class=\"t-name\">Calorie Calculator</div>\n      <div class=\"t-desc\">Daily energy needs</div>\n    </a>\n    <a href=\"calorie-deficit-calculator.html\" class=\"tool-item\">\n      <div class=\"t-icon\">📉</div>\n      <div class=\"t-name\">Calorie Deficit</div>\n      <div class=\"t-desc\">Weight loss timeline</div>\n    </a>\n    <a href=\"macro-calculator.html\" class=\"tool-item\">\n      <div class=\"t-icon\">🥗</div>\n      <div class=\"t-name\">Macro Calculator</div>\n      <div class=\"t-desc\">Protein, carbs & fat</div>\n    </a>\n    <a href=\"ideal-weight.html\" class=\"tool-item\">\n      <div class=\"t-icon\">🎯</div>\n      <div class=\"t-name\">Ideal Weight</div>\n      <div class=\"t-desc\">4 formula average</div>\n    </a>\n    <a href=\"body-fat.html\" class=\"tool-item\">\n      <div class=\"t-icon\">📊</div>\n      <div class=\"t-name\">Body Fat</div>\n      <div class=\"t-desc\">Navy circumference method</div>\n    </a>\n    <a href=\"water-intake.html\" class=\"tool-item\">\n      <div class=\"t-icon\">💧</div>\n      <div class=\"t-name\">Water Intake</div>\n      <div class=\"t-desc\">Daily hydration needs</div>\n    </a>\n    <a href=\"waist-to-height-ratio.html\" class=\"tool-item\">\n      <div class=\"t-icon\">📏</div>\n      <div class=\"t-name\">Waist-to-Height</div>\n      <div class=\"t-desc\">Metabolic risk indicator</div>\n    </a>\n    <a href=\"health-profile.html\" class=\"tool-item\">\n      <div class=\"t-icon\">👤</div>\n      <div class=\"t-name\">Health Profile</div>\n      <div class=\"t-desc\">All metrics in one place</div>\n    </a>\n  </div>\n\n  <!-- Science table -->\n  <h2 class=\"section-title\">The science behind our tools</h2>\n  <p class=\"section-sub\">Each calculator uses a specific formula validated in peer-reviewed research.</p>\n  <table class=\"formula-table\">\n    <thead>\n      <tr><th>Calculator</th><th>Formula / Method</th><th>Source</th></tr>\n    </thead>\n    <tbody>\n      <tr><td><a href=\"bmi-calculator.html\">BMI Calculator</a></td><td>Weight ÷ Height² (kg/m²)</td><td>World Health Organization (WHO)</td></tr>\n      <tr><td><a href=\"asian-bmi-calculator.html\">Asian BMI Calculator</a></td><td>WHO Asian cutoffs (≥23 overweight, ≥27.5 obese)</td><td>WHO Expert Consultation, The Lancet, 2004</td></tr>\n      <tr><td><a href=\"bmi-calculator-kids.html\">Kids BMI Calculator</a></td><td>CDC BMI-for-age LMS percentile method</td><td>CDC Growth Charts, Kuczmarski et al., 2000</td></tr>\n      <tr><td><a href=\"calorie-calculator.html\">Calorie Calculator</a></td><td>Mifflin–St Jeor equation × activity factor</td><td>Mifflin et al., Am J Clin Nutr, 1990</td></tr>\n      <tr><td><a href=\"calorie-deficit-calculator.html\">Calorie Deficit</a></td><td>TDEE − deficit; 7,700 kcal/kg fat rule</td><td>Hall et al., The Lancet, 2011</td></tr>\n      <tr><td><a href=\"macro-calculator.html\">Macro Calculator</a></td><td>Mifflin–St Jeor + protein 1.6–2.2 g/kg</td><td>Morton et al., Br J Sports Med, 2018</td></tr>\n      <tr><td><a href=\"ideal-weight.html\">Ideal Weight</a></td><td>Devine, Robinson, Miller, Hamwi formulas</td><td>Multiple peer-reviewed sources, 1964–1983</td></tr>\n      <tr><td><a href=\"body-fat.html\">Body Fat Calculator</a></td><td>U.S. Navy circumference method</td><td>Hodgdon & Beckett, NHRC, 1984</td></tr>\n      <tr><td><a href=\"water-intake.html\">Water Intake</a></td><td>Weight-based hydration guidelines</td><td>National Academies of Sciences, 2005</td></tr>\n      <tr><td><a href=\"waist-to-height-ratio.html\">Waist-to-Height Ratio</a></td><td>WHtR &lt; 0.5 healthy threshold</td><td>Ashwell et al., Obesity Reviews, 2012</td></tr>\n    </tbody>\n  </table>\n\n  <!-- Who We Are -->\n  <h2 class=\"section-title\">Who We Are</h2>\n  <div class=\"mission-block\">\n    <p><strong>HealthyBMICheck.com was founded in 2024</strong> by a small team of developers and health researchers based in Southeast Asia. We built this site because we were frustrated by health calculator websites that buried results behind sign-up walls, used outdated formulas, or surrounded sensitive health information with aggressive advertising.</p>\n    <p>Our team has backgrounds in health sciences, software development, and nutrition research. We are not a hospital, clinic, or medical institution — we are independent builders who care about making evidence-based health information accessible to everyone, for free.</p>\n    <p>All content and calculator formulas are reviewed against current clinical guidelines from the WHO, CDC, and NIH before publication, and updated when guidelines change. If you spot an error or outdated information, <a href=\"contact.html\" style=\"color:var(--accent);\">please let us know</a> — we take accuracy seriously.</p>\n    <p style=\"margin-bottom:0;\"><strong>Based in:</strong> Malaysia &nbsp;·&nbsp; <strong>Founded:</strong> 2024 &nbsp;·&nbsp; <strong>Contact:</strong> <a href=\"mailto:hello@healthybmicheck.com\" style=\"color:var(--accent);\">hello@healthybmicheck.com</a></p>\n  </div>\n\n  <!-- FAQ -->\n  <h2 class=\"section-title\">Frequently Asked Questions</h2>\n  <div class=\"mission-block\">\n    <h3 style=\"font-size:.95rem;font-weight:600;margin-bottom:6px;\">Are your calculators accurate?</h3>\n    <p>Our calculators use validated scientific formulas — the Mifflin-St Jeor equation for calories, WHO BMI classifications, the U.S. Navy method for body fat, and peer-reviewed ideal weight formulas. Results are population-level estimates, not clinical diagnoses. Individual variation (genetics, medications, body composition) means results should be used as a guide, not an absolute.</p>\n\n    <h3 style=\"font-size:.95rem;font-weight:600;margin-bottom:6px;margin-top:20px;\">Do you collect my health data?</h3>\n    <p>No. All calculations run entirely in your browser — no data is sent to our servers. We do not collect, store, or share any height, weight, age, or other health information you enter. See our <a href=\"privacy.html\" style=\"color:var(--accent);\">Privacy Policy</a> for full details.</p>\n\n    <h3 style=\"font-size:.95rem;font-weight:600;margin-bottom:6px;margin-top:20px;\">Why is this site free?</h3>\n    <p>HealthyBMICheck.com is supported by advertising through Google AdSense. This allows us to keep all tools free with no sign-up required. We have no premium plans, no data sales, and no sponsored content — ads are the only revenue source.</p>\n\n    <h3 style=\"font-size:.95rem;font-weight:600;margin-bottom:6px;margin-top:20px;\">Can I suggest a new calculator or topic?</h3>\n    <p style=\"margin-bottom:0;\">Absolutely. <a href=\"contact.html\" style=\"color:var(--accent);\">Send us a message</a> with your suggestion — we review all feedback and have added features based on reader requests.</p>\n  </div>\n\n    <!-- Disclaimer -->\n  <div class=\"warn-callout\">\n    ⚕️ <strong>Not medical advice.</strong> Our calculators are population-level estimates for general informational purposes only. Individual results may vary due to genetics, medications, body composition, and medical history. If you have health concerns or are planning significant lifestyle changes, consult a qualified healthcare professional.\n  </div>\n\n  <!-- Contact CTA -->\n  <div class=\"cta-block\">\n    <h2>Start using our free tools</h2>\n    <p>All calculators are free, instant, and require no sign-up.</p>\n    <div class=\"cta-buttons\">\n      <a href=\"bmi-calculator.html\" class=\"cta-btn\">⚖️ BMI Calculator</a>\n      <a href=\"calorie-calculator.html\" class=\"cta-btn cta-btn-ghost\">🔥 Calorie Calculator</a>\n      <a href=\"health-profile.html\" class=\"cta-btn cta-btn-ghost\">👤 Full Health Profile</a>\n    </div>\n  </div>\n\n  <div style=\"text-align:center;margin-top:16px;\">\n    <p style=\"font-size:.875rem;color:var(--ink3);\">Questions or feedback? <a href=\"contact.html\" style=\"color:var(--accent);\">Contact us →</a></p>\n  </div>\n\n</div>";
---

<Base
  title="About HealthyBMICheck.com — Free Health Calculators"
  description="HealthyBMICheck.com offers 11 free, evidence-based health calculators — BMI, calories, macros, body fat and more. No sign-up, no data collection, instant."
  canonical="https://healthybmicheck.com/about.html"
>
  <Fragment set:html={main} />
</Base>
