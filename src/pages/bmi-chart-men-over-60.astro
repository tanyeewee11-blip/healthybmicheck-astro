---
import Base from '../layouts/Base.astro';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "BMI Chart for Men Over 60 — Healthy Weight by Age & Height",
      "description": "BMI chart for men over 60. See healthy BMI ranges by age, average BMI for men in their 60s, and what the numbers actually mean for older men's health.",
      "author": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com",
        "url": "https://healthybmicheck.com"
      },
      "datePublished": "2025-05-10",
      "dateModified": "2026-06-17",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://healthybmicheck.com/bmi-chart-men-over-60.html"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is BMI 27 healthy for a man over 60?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BMI 27 puts a man in the \"overweight\" category by standard WHO guidelines. However, some research suggests that for adults over 65, a BMI in the 25–27 range may be associated with better outcomes than the standard healthy range of 18.5–24.9. This is thought to be due to nutritional reserves during illness. That said, waist circumference and muscle mass are better indicators of health risk than BMI at this age. If waist circumference is under 94 cm and physical fitness is maintained, a BMI of 27 is unlikely to represent a significant health concern for most men over 60."
          }
        },
        {
          "@type": "Question",
          "name": "What is the most important thing for health after 60 — weight loss or muscle gain?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For most men over 60, preserving and building muscle mass (through resistance training and adequate protein) delivers more health benefit than weight loss alone. Muscle mass supports metabolic rate, bone density, functional independence, and cardiovascular health. A man who loses 5 kg of fat while maintaining muscle is in a far better health position than one who loses 5 kg of mixed fat and muscle. If weight loss is needed, prioritise preserving muscle by using a moderate deficit (300–500 kcal/day) with 1.6–2.0 g protein/kg/day and resistance training."
          }
        },
        {
          "@type": "Question",
          "name": "Does BMI account for age?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No — standard BMI categories (underweight, healthy, overweight, obese) are the same for all adults regardless of age. This is a recognised limitation: the same BMI in a 65-year-old represents a different body composition than in a 25-year-old due to age-related muscle loss and fat redistribution. Some researchers argue for age-adjusted BMI thresholds, but official guidelines (WHO, CDC, NHS) have not adopted this approach. In practice, clinicians often supplement BMI with waist circumference and other markers when assessing older adults."
          }
        }
      ]
    }
  ]
});

const breadcrumbJson = JSON.stringify({"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthybmicheck.com/"}, {"@type": "ListItem", "position": 2, "name": "BMI Chart for Men Over 60 — Healthy Weight by Age & Height", "item": "https://healthybmicheck.com/bmi-chart-men-over-60.html"}]});
