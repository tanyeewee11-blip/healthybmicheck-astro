<script is:inline>
let currentUnit = 'imperial';
let currentSex2 = 'both';

function showUnit(unit) {
  currentUnit = unit;
  document.getElementById('unit-imperial').style.display = unit === 'imperial' ? '' : 'none';
  document.getElementById('unit-metric').style.display = unit === 'metric' ? '' : 'none';
  ['imperial','metric'].forEach(u => {
    const btn = document.getElementById('btn-' + u);
    btn.style.background = u === unit ? 'var(--accent)' : 'transparent';
    btn.style.color = u === unit ? '#fff' : 'var(--ink2)';
    btn.style.borderColor = u === unit ? 'var(--accent)' : 'var(--border)';
  });
  applySex2();
}

function showSex2(sex) {
  currentSex2 = sex;
  ['both','female','male'].forEach(s => {
    const btn = document.getElementById('btn2-' + s);
    btn.style.background = s === sex ? 'var(--accent)' : 'transparent';
    btn.style.color = s === sex ? '#fff' : 'var(--ink2)';
    btn.style.borderColor = s === sex ? 'var(--accent)' : 'var(--border)';
  });
  applySex2();
}

function applySex2() {
  const showF = currentSex2 === 'both' || currentSex2 === 'female';
  const showM = currentSex2 === 'both' || currentSex2 === 'male';
  ['imp-female','met-female'].forEach(id => { const el = document.getElementById(id); if(el) el.style.display = showF ? '' : 'none'; });
  ['imp-male','met-male'].forEach(id => { const el = document.getElementById(id); if(el) el.style.display = showM ? '' : 'none'; });
}
</script>



