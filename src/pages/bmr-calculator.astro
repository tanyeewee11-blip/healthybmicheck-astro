<div style="max-width:720px;margin:0 auto;padding:0 20px 40px;">
  <div style="background:#F0F7F4;border:1px solid #B7DDD0;border-radius:12px;padding:20px 24px;font-size:0.82rem;color:#2D4A3E;line-height:1.8;">
    <strong style="display:block;margin-bottom:8px;">📚 References</strong>
    <ol style="margin:8px 0 8px 18px;padding:0;">
      <li>Mifflin MD et al. (1990). <em>A new predictive equation for resting energy expenditure in healthy individuals</em>. Am J Clin Nutr. <a href="https://doi.org/10.1093/ajcn/51.2.241" style="color:var(--accent);">doi:10.1093/ajcn/51.2.241</a></li>
      <li>Harris JA, Benedict FG. (1918). <em>A Biometric Study of Human Basal Metabolism</em>. PNAS. <a href="https://doi.org/10.1073/pnas.4.12.370" style="color:var(--accent);">doi:10.1073/pnas.4.12.370</a></li>
      <li>Frankenfield D et al. (2005). <em>Comparison of predictive equations for resting metabolic rate in healthy nonobese and obese adults</em>. J Am Diet Assoc. <a href="https://doi.org/10.1016/j.jada.2005.05.003" style="color:var(--accent);">doi:10.1016/j.jada.2005.05.003</a></li>
    </ol>
    Not a substitute for professional medical or dietary advice. Last updated June 2026.
  </div>
</div>

<script>
let gender = 'male';
let unit = 'metric';

function setUnit(u) {
  unit = u;
  document.querySelectorAll('.unit-toggle button').forEach((b,i) => b.classList.toggle('active', (u==='metric'&&i===0)||(u==='imperial'&&i===1)));
  document.getElementById('metric-weight-wrap').style.display = u==='metric' ? '' : 'none';
  document.getElementById('imperial-weight-wrap').style.display = u==='imperial' ? '' : 'none';
  document.getElementById('metric-height-wrap').style.display = u==='metric' ? '' : 'none';
  document.getElementById('imperial-height-wrap').style.display = u==='imperial' ? '' : 'none';
}

function setGender(g, btn) {
  gender = g;
  document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function calculate() {
  const age = parseFloat(document.getElementById('age').value);
  let weightKg, heightCm;

  if (unit === 'metric') {
    weightKg = parseFloat(document.getElementById('weight-kg').value);
    heightCm = parseFloat(document.getElementById('height-cm').value);
  } else {
    const lb = parseFloat(document.getElementById('weight-lb').value);
    const ft = parseFloat(document.getElementById('height-ft').value) || 0;
    const inches = parseFloat(document.getElementById('height-in').value) || 0;
    weightKg = lb * 0.453592;
    heightCm = (ft * 12 + inches) * 2.54;
  }

  if (!age || !weightKg || !heightCm || age < 15 || age > 100) {
    alert('Please fill in all fields with valid values.');
    return;
  }

  // Mifflin-St Jeor
  let mifflin = (10 * weightKg) + (6.25 * heightCm) - (5 * age);
  mifflin += gender === 'male' ? 5 : -161;

  // Harris-Benedict (revised 1984)
  let harris;
  if (gender === 'male') {
    harris = 88.362 + (13.397 * weightKg) + (4.799 * heightCm) - (5.677 * age);
  } else {
    harris = 447.593 + (9.247 * weightKg) + (3.098 * heightCm) - (4.330 * age);
  }

  const bmr = Math.round(mifflin);

  document.getElementById('bmr-num').textContent = bmr.toLocaleString() + ' kcal';
  document.getElementById('mifflin-result').textContent = Math.round(mifflin).toLocaleString() + ' kcal';
  document.getElementById('harris-result').textContent = Math.round(harris).toLocaleString() + ' kcal';

  // TDEE rows
  const activities = [
    { label: 'Sedentary (desk job, no exercise)', factor: 1.2 },
    { label: 'Lightly active (exercise 1–3×/week)', factor: 1.375 },
    { label: 'Moderately active (exercise 3–5×/week)', factor: 1.55 },
    { label: 'Very active (exercise 6–7×/week)', factor: 1.725 },
    { label: 'Extra active (physical job + training)', factor: 1.9 },
  ];

  const tdeeRows = document.getElementById('tdee-rows');
  tdeeRows.innerHTML = activities.map(a => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:var(--surface);border-radius:8px;font-size:.85rem;">
      <span style="color:var(--ink2);">${a.label}</span>
      <strong style="color:var(--accent);white-space:nowrap;margin-left:12px;">${Math.round(bmr * a.factor).toLocaleString()} kcal</strong>
    </div>
  `).join('');

  document.getElementById('result-card').classList.add('visible');
  document.getElementById('formula-breakdown').style.display = '';
  document.getElementById('tdee-section').style.display = '';
  document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}
</script>

</Base>
