---
import Base from '../layouts/Base.astro';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Health Profile Calculator — All Your Metrics at Once",
      "description": "Enter your details once and instantly get your BMI, daily calorie needs, ideal weight, body fat percentage, and water intake — all in one place.",
      "author": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "HealthyBMICheck.com",
        "url": "https://healthybmicheck.com"
      },
      "datePublished": "2025-05-10",
      "dateModified": "2026-06-17",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://healthybmicheck.com/health-profile.html"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does the Health Profile calculator measure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Health Profile calculator gives you six key metrics in one place: BMI (with both standard and Asian cutoffs), daily calorie needs (TDEE and BMR), ideal weight range using four clinical formulas, body fat estimate, daily water requirement, and calorie targets for weight loss or gain. It replaces running six separate calculators."
          }
        },
        {
          "@type": "Question",
          "name": "How accurate is the Health Profile calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Each metric uses the most validated formula available: Mifflin-St Jeor for calories (±10% for most adults), Devine/Robinson/Miller/Hamwi for ideal weight, and the U.S. Navy method for body fat (±3–4%). These are the same formulas used in clinical settings. Treat results as a precise starting point, not a medical diagnosis."
          }
        },
        {
          "@type": "Question",
          "name": "Should I use standard BMI or Asian BMI for my result?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If you are of East Asian, Southeast Asian, or South Asian descent, the Asian BMI cutoffs (overweight ≥23, obese ≥27.5) are more appropriate — research shows Asian populations carry higher metabolic risk at lower BMI values. The calculator shows both so you can compare. Malaysia, Singapore, and most Asian health authorities follow the Asian standard."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I recalculate my health profile?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Recalculate whenever your weight changes by 5 kg or more, when you significantly change your activity level, or every 8–12 weeks during an active weight loss or gain phase. Your TDEE changes as your body weight changes — using outdated numbers is one of the most common reasons progress stalls."
          }
        },
        {
          "@type": "Question",
          "name": "Why does my ideal weight range span several kilograms?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The ideal weight range reflects four different clinical formulas (Devine, Robinson, Miller, Hamwi) that each define 'ideal' slightly differently based on height and sex. The range represents the consensus across these formulas. Research shows body composition (muscle-to-fat ratio) matters more than hitting a specific weight within this range."
          }
        }
      ]
    },
    {
    "@type": "HowTo",
    "name": "How to Build Your Full Health Profile",
    "description": "Combine BMI, body fat, waist measurements, and activity level into one comprehensive health snapshot.",
    "totalTime": "PT3M",
    "tool": [
        {
            "@type": "HowToTool",
            "name": "HealthyBMICheck Health Profile Tool"
        },
        {
            "@type": "HowToTool",
            "name": "Measuring tape (optional)"
        }
    ],
    "step": [
        {
            "@type": "HowToStep",
            "name": "Enter your basic details",
            "text": "Input your sex, age, height, and weight. These are used across all health metrics."
        },
        {
            "@type": "HowToStep",
            "name": "Add optional body measurements",
            "text": "Enter your waist, neck, and hip measurements for body fat estimation and waist-to-height ratio."
        },
        {
            "@type": "HowToStep",
            "name": "Select your activity level",
            "text": "Choose how active you typically are each week. This affects your TDEE and health risk assessment."
        },
        {
            "@type": "HowToStep",
            "name": "Review your full health snapshot",
            "text": "See your BMI, weight category, estimated body fat %, waist-to-height ratio, TDEE, and overall health score \u2014 all in one place."
        }
    ]
}
  ]
});

const breadcrumbJson = JSON.stringify({"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthybmicheck.com/"}, {"@type": "ListItem", "position": 2, "name": "Health Profile Calculator — All Your Metrics at Once", "item": "https://healthybmicheck.com/health-profile.html"}]});
---

<Base
  breadcrumbJson={breadcrumbJson}
  schemaJson={schemaJson}
  title="Health Profile Calculator — All Your Metrics at Once"
  description="Enter your details once and instantly get your BMI, daily calorie needs, ideal weight, body fat percentage, and water intake — all in one place."
  canonical="https://healthybmicheck.com/health-profile.html"
>
<div class="hero">
    <div class="breadcrumb"><a href="index.html" class="breadcrumb-link">Home</a> › Health Profile Calculator</div>
  <h1>Your Complete <em>Health Profile</em></h1>
  <p>Fill in your details once — get your BMI, calories, ideal weight, body fat, and water intake all at once.</p>
</div>

<div class="calc-byline">Reviewed by <strong>Sarah Mitchell, BSc Nutrition</strong> · Last updated: <strong>July 2026</strong></div>

<div class="page-wrap">

  <!-- Input form -->
  <div class="form-card" id="form-section">
    <h2>Enter Your Details</h2>
    <p class="subtitle">All calculations happen in your browser. No data is stored or sent anywhere.</p>

    <!-- Unit toggle -->
    <div class="unit-toggle">
      <button class="active" onclick="setUnit('metric')">Metric</button>
      <button onclick="setUnit('imperial')">Imperial</button>
    </div>

    <!-- Sex -->
    <div class="gender-row">
      <button class="gender-btn active" onclick="setGender('male',this)">
        <span class="g-icon">♂</span>Male
      </button>
      <button class="gender-btn" onclick="setGender('female',this)">
        <span class="g-icon">♀</span>Female
      </button>
    </div>

    <div class="fields-grid">

      <!-- Age -->
      <div class="field">
        <label>Age</label>
        <div class="input-wrap">
          <input type="number" id="age" placeholder="28" min="15" max="100">
          <span class="unit-badge">yrs</span>
        </div>
      </div>

      <!-- Activity -->
      <div class="field">
        <label for="activity">Activity Level</label>
        <select id="activity">
          <option value="1.2">Sedentary (little exercise)</option>
          <option value="1.375">Lightly active (1–3×/week)</option>
          <option value="1.55" selected>Moderately active (3–5×/week)</option>
          <option value="1.725">Very active (6–7×/week)</option>
          <option value="1.9">Extra active (physical job)</option>
        </select>
      </div>

      <!-- Weight -->
      <div class="field" id="weight-field-metric">
        <label>Weight</label>
        <div class="input-wrap">
          <input type="number" id="weight-kg" placeholder="70" min="20" max="500">
          <span class="unit-badge">kg</span>
        </div>
      </div>
      <div class="field" id="weight-field-imperial" style="display:none">
        <label>Weight</label>
        <div class="input-wrap">
          <input type="number" id="weight-lb" placeholder="154" min="44" max="1100">
          <span class="unit-badge">lb</span>
        </div>
      </div>

      <!-- Height -->
      <div class="field" id="height-field-metric">
        <label>Height</label>
        <div class="input-wrap">
          <input type="number" id="height-cm" placeholder="170" min="100" max="250">
          <span class="unit-badge">cm</span>
        </div>
      </div>
      <div class="field" id="height-field-imperial" style="display:none">
        <label>Height</label>
        <div class="height-row">
          <div class="input-wrap">
            <input type="number" id="height-ft" placeholder="5" min="3" max="8">
            <span class="unit-badge">ft</span>
          </div>
          <div class="input-wrap">
            <input type="number" id="height-in2" placeholder="7" min="0" max="11">
            <span class="unit-badge">in</span>
          </div>
        </div>
      </div>

      <!-- Waist (for body fat) -->
      <div class="field">
        <label>Waist <span class="optional-tag">for body fat</span></label>
        <div class="input-wrap">
          <input type="number" id="waist" placeholder="85">
          <span class="unit-badge" id="waist-u">cm</span>
        </div>
      </div>

      <!-- Neck (for body fat) -->
      <div class="field">
        <label>Neck <span class="optional-tag">for body fat</span></label>
        <div class="input-wrap">
          <input type="number" id="neck" placeholder="38">
          <span class="unit-badge" id="neck-u">cm</span>
        </div>
      </div>

      <!-- Hip (female only) -->
      <div class="field" id="hip-field" style="display:none">
        <label>Hips <span class="optional-tag">widest point</span></label>
        <div class="input-wrap">
          <input type="number" id="hip" placeholder="95">
          <span class="unit-badge" id="hip-u">cm</span>
        </div>
      </div>

      <!-- Climate -->
      <div class="field">
        <label for="climate">Climate</label>
        <select id="climate">
          <option value="0">Cool / temperate</option>
          <option value="0.35" selected>Warm / humid (tropical)</option>
          <option value="0.7">Hot / very humid</option>
        </select>
      </div>

    </div>

    <button class="calculate-btn" onclick="calculateAll()">
      Generate My Health Profile →
    </button>
  </div>

  <!-- Results -->
  <div class="results-section" id="results-section">

    <div class="results-header">
      <h2>Your Health Profile</h2>
      <p>Based on the details you entered. All values are estimates — consult a professional for medical advice.</p>
    </div>

    <!-- Summary bar -->
    <div class="summary-card">
      <div class="sum-item"><span class="sum-val" id="s-bmi">—</span><span class="sum-label">BMI</span></div>
      <div class="sum-item"><span class="sum-val" id="s-cal">—</span><span class="sum-label">Cal/day</span></div>
      <div class="sum-item"><span class="sum-val" id="s-iw">—</span><span class="sum-label">Ideal weight</span></div>
      <div class="sum-item"><span class="sum-val" id="s-bf">—</span><span class="sum-label">Body fat</span></div>
      <div class="sum-item"><span class="sum-val" id="s-water">—</span><span class="sum-label">Water/day</span></div>
    </div>

    <div class="results-grid">

      <!-- BMI -->
      <div class="result-card" style="--card-color: #2D6A4F; --card-bg: #D8EFE4;">
        <span class="rc-icon">⚖️</span>
        <div class="rc-label">Body Mass Index</div>
        <div class="rc-value" id="r-bmi">—</div>
        <div class="rc-unit">kg/m²</div>
        <div class="rc-badge" id="r-bmi-cat">—</div>
        <div class="rc-bar"><div class="rc-bar-fill" id="r-bmi-bar"></div></div>
        <div class="rc-tip" id="r-bmi-tip"></div>
      </div>

      <!-- Calories -->
      <div class="result-card" style="--card-color: #C17B2A; --card-bg: #FBF0DC;">
        <span class="rc-icon">🔥</span>
        <div class="rc-label">Daily Calorie Needs (TDEE)</div>
        <div class="rc-value" id="r-cal">—</div>
        <div class="rc-unit">calories per day to maintain weight</div>
        <div class="goal-mini">
          <div class="goal-mini-box"><div class="gml">Lose 0.5kg/wk</div><div class="gmv" id="r-cal-lose">—</div></div>
          <div class="goal-mini-box"><div class="gml">Gain 0.5kg/wk</div><div class="gmv" id="r-cal-gain">—</div></div>
        </div>
        <div class="rc-tip" id="r-cal-tip"></div>
      </div>

      <!-- Ideal Weight -->
      <div class="result-card" style="--card-color: #3A7BBF; --card-bg: #DCE9F8;">
        <span class="rc-icon">🎯</span>
        <div class="rc-label">Ideal Weight Range</div>
        <div class="rc-value" id="r-iw">—</div>
        <div class="rc-unit" id="r-iw-unit">kg (average of 4 formulas)</div>
        <div class="rc-bar"><div class="rc-bar-fill" id="r-iw-bar"></div></div>
        <div class="rc-tip" id="r-iw-tip"></div>
      </div>

      <!-- Body Fat -->
      <div class="result-card" style="--card-color: #7C3AED; --card-bg: #EDE9FE;" id="bf-card">
        <span class="rc-icon">📊</span>
        <div class="rc-label">Body Fat Percentage</div>
        <div class="rc-value" id="r-bf">—</div>
        <div class="rc-unit">% estimated body fat</div>
        <div class="rc-badge" id="r-bf-cat">—</div>
        <div class="rc-bar"><div class="rc-bar-fill" id="r-bf-bar"></div></div>
        <div class="rc-tip" id="r-bf-tip"></div>
      </div>

      <!-- Water -->
      <div class="result-card" style="--card-color: #0E7490; --card-bg: #E0F2FE;">
        <span class="rc-icon">💧</span>
        <div class="rc-label">Daily Water Intake</div>
        <div class="rc-value" id="r-water">—</div>
        <div class="rc-unit" id="r-water-unit">litres per day</div>
        <div class="cups-mini" id="r-cups"></div>
        <div class="rc-tip" id="r-water-tip"></div>
      </div>

      <!-- Healthy Weight Range (BMI-based) -->
      <div class="result-card" style="--card-color: #2D6A4F; --card-bg: #D8EFE4;">
        <span class="rc-icon">📏</span>
        <div class="rc-label">Healthy Weight Range (BMI)</div>
        <div class="rc-value" id="r-hw">—</div>
        <div class="rc-unit" id="r-hw-unit">for your height (BMI 18.5–24.9)</div>
        <div class="rc-bar"><div class="rc-bar-fill" id="r-hw-bar"></div></div>
        <div class="rc-tip" id="r-hw-tip"></div>
      </div>

    </div>

    <button class="recalc-btn" onclick="recalculate()">← Edit my details</button>
    </div>

</div>


  <div class="container">
    <div style="padding-top:32px;border-top:1px solid #E5E0D8;">
      <h3 style="font-family:DM Serif Display,serif;font-size:1.2rem;margin-bottom:16px;">Related Tools</h3>
      <div style="display:flex;flex-wrap:wrap;gap:10px;">
        <a href="bmi-calculator.html" class="related-link">BMI Calculator</a>
        <a href="calorie-calculator.html" class="related-link">Calorie Calculator</a>
        <a href="ideal-weight.html" class="related-link">Ideal Weight Calculator</a>
        <a href="body-fat.html" class="related-link">Body Fat Calculator</a>
        <a href="water-intake.html" class="related-link">Water Intake Calculator</a>
        <a href="asian-bmi-calculator.html" class="related-link">Asian BMI Calculator</a>
        <a href="bmi-calculator-kids.html" class="related-link">Kids BMI Calculator</a>
        <a href="waist-to-height-ratio.html" class="related-link">Waist-to-Height Ratio</a>
      </div>
    </div>
  </div>



<script is:inline>
  let unit = 'metric', gender = 'male';

  function setUnit(u) {
    unit = u;
    document.querySelectorAll('.unit-toggle button').forEach((b,i) => b.classList.toggle('active',(u==='metric'&&i===0)||(u==='imperial'&&i===1)));
    document.getElementById('weight-field-metric').style.display = u==='metric'?'':'none';
    document.getElementById('weight-field-imperial').style.display = u==='imperial'?'':'none';
    document.getElementById('height-field-metric').style.display = u==='metric'?'':'none';
    document.getElementById('height-field-imperial').style.display = u==='imperial'?'':'none';
    const badge = u==='metric'?'cm':'in';
    ['waist-u','neck-u','hip-u'].forEach(id => document.getElementById(id).textContent = badge);
  }

  function setGender(g, btn) {
    gender = g;
    document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('hip-field').style.display = g==='female'?'':'none';
  }

  function toIn(val) { return unit==='metric' ? val/2.54 : val; }

  function calculateAll() {
    // ── Gather inputs ──
    let weightKg, heightCm;
    if(unit==='metric') {
      weightKg = parseFloat(document.getElementById('weight-kg').value);
      heightCm = parseFloat(document.getElementById('height-cm').value);
    } else {
      weightKg = parseFloat(document.getElementById('weight-lb').value) * 0.453592;
      const ft = parseFloat(document.getElementById('height-ft').value)||0;
      const ins = parseFloat(document.getElementById('height-in2').value)||0;
      heightCm = (ft*12+ins)*2.54;
    }
    const age      = parseFloat(document.getElementById('age').value);
    const activity = parseFloat(document.getElementById('activity').value);
    const climate  = parseFloat(document.getElementById('climate').value);

    if(!weightKg || !heightCm || !age) { alert('Please fill in age, weight, and height to continue.'); return; }

    const heightM  = heightCm / 100;
    const heightIn = heightCm / 2.54;

    // ── 1. BMI ──
    const bmi     = weightKg / (heightM * heightM);
    const bmiR    = Math.round(bmi * 10) / 10;
    let bmiCat, bmiTip, bmiBarPct;
    if(bmi < 18.5)      { bmiCat='Underweight'; bmiTip='Your BMI suggests you may be underweight. A balanced diet with adequate calories and strength training can help you reach a healthier weight.'; bmiBarPct=15; }
    else if(bmi < 25)   { bmiCat='Normal Weight'; bmiTip='Your BMI is in the healthy range. Keep it up with regular physical activity and a balanced diet.'; bmiBarPct=45; }
    else if(bmi < 30)   { bmiCat='Overweight'; bmiTip='Your BMI is slightly above the healthy range. Small, consistent improvements in diet and activity can make a real difference over time.'; bmiBarPct=70; }
    else                { bmiCat='Obese'; bmiTip='Your BMI is in the obese range. Reaching a healthier weight can significantly reduce risks of chronic disease. Consider speaking with a healthcare professional.'; bmiBarPct=90; }

    // ── 2. Calories (Mifflin-St Jeor) ──
    let bmr;
    if(gender==='male') bmr = 10*weightKg + 6.25*heightCm - 5*age + 5;
    else                bmr = 10*weightKg + 6.25*heightCm - 5*age - 161;
    const tdee = Math.round(bmr * activity);

    // ── 3. Ideal Weight (average of 4 formulas) ──
    const inchesOver5 = heightIn - 60;
    let dev, rob, mil, ham;
    if(gender==='male') { dev=50+2.3*inchesOver5; rob=52+1.9*inchesOver5; mil=56.2+1.41*inchesOver5; ham=48+2.7*inchesOver5; }
    else                { dev=45.5+2.3*inchesOver5; rob=49+1.7*inchesOver5; mil=53.1+1.36*inchesOver5; ham=45.5+2.2*inchesOver5; }
    const iwMin = Math.min(dev,rob,mil,ham), iwMax = Math.max(dev,rob,mil,ham);
    const iwMid = (iwMin+iwMax)/2;
    const iwBarPct = Math.min(100, Math.max(0, (weightKg - iwMin) / (iwMax - iwMin + 0.001) * 100));
    let iwTip;
    if(weightKg < iwMin-2)      iwTip = 'Your current weight is below your ideal range. Focusing on nutrient-dense foods and strength training can help you reach a healthier weight.';
    else if(weightKg > iwMax+2) iwTip = 'Your current weight is above your ideal range. Gradual, sustainable changes to diet and activity tend to produce the best long-term results.';
    else                        iwTip = 'Your weight is within or very close to your ideal range based on your height. Keep maintaining your healthy lifestyle.';

    // ── 4. Body Fat (US Navy) ──
    const waistRaw = parseFloat(document.getElementById('waist').value);
    const neckRaw  = parseFloat(document.getElementById('neck').value);
    let bf = null, bfCat = '—', bfTip = 'Enter your waist and neck measurements above to calculate body fat.', bfBarPct = 0;
    if(waistRaw && neckRaw) {
      const waistIn = toIn(waistRaw), neckIn = toIn(neckRaw);
      if(gender==='male') {
        bf = 86.010 * Math.log10(waistIn - neckIn) - 70.041 * Math.log10(heightIn) + 36.76;
      } else {
        const hipRaw = parseFloat(document.getElementById('hip').value);
        if(hipRaw) {
          const hipIn = toIn(hipRaw);
          bf = 163.205 * Math.log10(waistIn + hipIn - neckIn) - 97.684 * Math.log10(heightIn) - 78.387;
        }
      }
      if(bf !== null) {
        bf = Math.max(2, Math.min(60, bf));
        bfBarPct = Math.min(98, bf / 50 * 100);
        if(gender==='male') {
          if(bf<6)       { bfCat='Essential Fat'; bfTip='You are at the essential fat level. Ensure you are eating enough to support basic physiological functions.'; }
          else if(bf<14) { bfCat='Athletic'; bfTip='Your body fat is in the athletic range — excellent body composition.'; }
          else if(bf<18) { bfCat='Fitness'; bfTip='Your body fat is in a healthy fitness range. Keep up your current routine.'; }
          else if(bf<25) { bfCat='Acceptable'; bfTip='Your body fat is acceptable. Increasing activity and refining your diet can gradually improve your composition.'; }
          else           { bfCat='Obese'; bfTip='Your body fat percentage is elevated. A combination of calorie control and regular exercise can help reduce it safely.'; }
        } else {
          if(bf<14)      { bfCat='Essential Fat'; bfTip='You are at the essential fat level for women. Monitor closely with a healthcare professional.'; }
          else if(bf<21) { bfCat='Athletic'; bfTip='Your body fat is in the athletic range — great body composition for your health.'; }
          else if(bf<25) { bfCat='Fitness'; bfTip='Your body fat is in a healthy fitness range. Maintain your current active lifestyle.'; }
          else if(bf<32) { bfCat='Acceptable'; bfTip='Your body fat is acceptable. Regular exercise and mindful eating can gradually improve your composition.'; }
          else           { bfCat='Obese'; bfTip='Your body fat percentage is elevated. A sustainable plan of diet and exercise can help you reach a healthier range.'; }
        }
      }
    }

    // ── 5. Water Intake ──
    const baseMl = weightKg * 35;
    const actMl  = weightKg * (activity - 1.2) / (1.9 - 1.2) * 10 * 10;
    const climMl = weightKg * climate * 10;
    const waterMl = Math.round((baseMl + actMl + climMl) / 50) * 50;
    const waterL  = (waterMl / 1000).toFixed(1);
    const glasses = Math.ceil(waterMl / 250);

    // ── Healthy weight range ──
    const hwMin = 18.5 * heightM * heightM, hwMax = 24.9 * heightM * heightM;
    const hwBarPct = Math.min(98, Math.max(2, (weightKg - hwMin) / (hwMax - hwMin + 0.001) * 100));
    let hwTip;
    if(weightKg < hwMin)      hwTip = 'Your current weight is below the healthy BMI range for your height.';
    else if(weightKg > hwMax) hwTip = 'Your current weight is above the healthy BMI range for your height.';
    else                      hwTip = 'Your current weight falls within the healthy BMI range for your height.';

    // ── Format values ──
    function fmtKg(kg) { return unit==='metric' ? kg.toFixed(1)+' kg' : (kg/0.453592).toFixed(1)+' lb'; }

    // ── Update DOM ──
    // Summary
    document.getElementById('s-bmi').textContent   = bmiR.toFixed(1);
    document.getElementById('s-cal').textContent   = tdee.toLocaleString();
    document.getElementById('s-iw').textContent    = fmtKg(iwMid);
    document.getElementById('s-bf').textContent    = bf !== null ? bf.toFixed(1)+'%' : 'N/A';
    document.getElementById('s-water').textContent = waterL+'L';

    // BMI card
    document.getElementById('r-bmi').textContent     = bmiR.toFixed(1);
    document.getElementById('r-bmi-cat').textContent = bmiCat;
    document.getElementById('r-bmi-tip').textContent = bmiTip;
    setTimeout(() => document.getElementById('r-bmi-bar').style.width = bmiBarPct+'%', 100);

    // Calories card
    document.getElementById('r-cal').textContent      = tdee.toLocaleString();
    document.getElementById('r-cal-lose').textContent = (tdee-500).toLocaleString()+' cal';
    document.getElementById('r-cal-gain').textContent = (tdee+500).toLocaleString()+' cal';
    document.getElementById('r-cal-tip').textContent  = `Your BMR is ${Math.round(bmr).toLocaleString()} cal/day. The ${tdee.toLocaleString()} cal figure includes your activity level.`;

    // Ideal weight card
    document.getElementById('r-iw').textContent      = fmtKg(iwMin)+' – '+fmtKg(iwMax);
    document.getElementById('r-iw-unit').textContent = (unit==='metric'?'kg':'lb')+' — average of Devine, Robinson, Miller & Hamwi formulas';
    document.getElementById('r-iw-tip').textContent  = iwTip;
    setTimeout(() => document.getElementById('r-iw-bar').style.width = Math.min(98, Math.max(2, iwBarPct))+'%', 100);

    // Body fat card
    if(bf !== null) {
      document.getElementById('r-bf').textContent      = bf.toFixed(1)+'%';
      document.getElementById('r-bf-cat').textContent  = bfCat;
      document.getElementById('r-bf-tip').textContent  = bfTip;
      setTimeout(() => document.getElementById('r-bf-bar').style.width = bfBarPct+'%', 100);
    } else {
      document.getElementById('r-bf').textContent     = '—';
      document.getElementById('r-bf-cat').textContent = 'Add waist & neck';
      document.getElementById('r-bf-tip').textContent = bfTip;
    }

    // Water card
    document.getElementById('r-water').textContent      = waterL;
    document.getElementById('r-water-unit').textContent = `litres/day · ${(waterMl/29.5735).toFixed(0)} fl oz · ${glasses} glasses`;
    let cupsHtml = '';
    for(let i=0;i<Math.min(glasses,16);i++) cupsHtml += '🥛';
    if(glasses>16) cupsHtml += ` +${glasses-16}`;
    document.getElementById('r-cups').innerHTML       = cupsHtml;
    document.getElementById('r-water-tip').textContent = 'Living in a tropical climate increases your needs. Carry a 500ml bottle and aim to finish it based on your bottle count.';

    // Healthy weight card
    document.getElementById('r-hw').textContent      = fmtKg(hwMin)+' – '+fmtKg(hwMax);
    document.getElementById('r-hw-unit').textContent = `${unit==='metric'?'kg':'lb'} for your height (BMI 18.5–24.9)`;
    document.getElementById('r-hw-tip').textContent  = hwTip;
    setTimeout(() => document.getElementById('r-hw-bar').style.width = Math.min(98, Math.max(2, hwBarPct))+'%', 100);

    // Show results
    document.getElementById('form-section').style.display = 'none';
    document.getElementById('results-section').classList.add('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function recalculate() {
    document.getElementById('form-section').style.display = 'block';
    document.getElementById('results-section').classList.remove('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>

