    <button class="filter-btn" onclick="filterCards('Exercise',this)">Exercise <span style="background:rgba(45,106,79,0.15);border-radius:100px;padding:1px 7px;font-size:.75rem;margin-left:4px;color:var(--accent);">7</span></button>
    <button class="filter-btn" onclick="filterCards('Hydration',this)">Hydration <span style="background:rgba(45,106,79,0.15);border-radius:100px;padding:1px 7px;font-size:.75rem;margin-left:4px;color:var(--accent);">4</span></button>
