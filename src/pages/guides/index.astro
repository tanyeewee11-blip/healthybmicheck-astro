---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Health Guides — BMI, Calories & Weight Loss"
  description="Evidence-based health guides covering BMI, calorie needs, weight loss, nutrition, and exercise. Free, research-backed articles to help you reach your health goals."
  canonical="https://healthybmicheck.com/guides"
>
<main>

  <div class="hero">
    <h1>Health <em>Guides</em></h1>
    <p>Evidence-based articles on BMI, weight loss, nutrition, and exercise — written to help you understand your health, not just track numbers.</p>
  </div>

  <!-- Search box -->
  <div style="max-width:480px;margin:0 auto 24px;padding:0 24px;">
    <div style="position:relative;">
      <input id="guide-search" type="text" placeholder="Search guides… e.g. protein, BMI, sleep"
        style="width:100%;padding:11px 16px 11px 44px;border:1.5px solid var(--border);border-radius:100px;font-family:inherit;font-size:.9rem;background:var(--surface);color:var(--ink);outline:none;transition:border-color .2s;"
        oninput="searchGuides(this.value)" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'">
      <span style="position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:1rem;pointer-events:none;">🔍</span>
    </div>
  </div>

  <div class="section">

  <!-- Filter tabs -->
