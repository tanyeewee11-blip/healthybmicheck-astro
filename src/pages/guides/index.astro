    <button class="filter-btn active" onclick="filterCards('all',this)" id="tab-all">All <span style="background:rgba(255,255,255,0.25);border-radius:100px;padding:1px 7px;font-size:.75rem;margin-left:4px;">59</span></button>
    <button class="filter-btn" onclick="filterCards('BMI',this)">BMI <span style="background:rgba(45,106,79,0.15);border-radius:100px;padding:1px 7px;font-size:.75rem;margin-left:4px;color:var(--accent);">14</span></button>
    <button class="filter-btn" onclick="filterCards('Calories',this)">Calories <span style="background:rgba(45,106,79,0.15);border-radius:100px;padding:1px 7px;font-size:.75rem;margin-left:4px;color:var(--accent);">14</span></button>
