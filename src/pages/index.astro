    var shared   = 'flex:1;padding:9px 0;border-radius:8px;font-size:.875rem;font-weight:600;cursor:pointer;';
    document.getElementById('ba-gender-female').style.cssText = shared + (g==='female' ? active : inactive);
    document.getElementById('ba-gender-male').style.cssText   = shared + (g==='male'   ? active : inactive);
    baUpdateLink();
  }

  document.getElementById('ba-age-select').addEventListener('change', baUpdateLink);
  </script>
</main>

