---
import Base from '../layouts/Base.astro';
---

<Base
  title="Free Health Calculators — BMI, Calories, Ideal Weight & More"
  description="Free online health calculators. Calculate your BMI, daily calorie needs, ideal weight, body fat percentage, and water intake. Instant results, no sign-up."
  canonical="https://healthybmicheck.com/"
>
<main>

  <!-- Hero -->
  <!-- Returning user: last results banner (shown by JS if localStorage has data) -->
  <div id="returning-banner" style="display:none;max-width:720px;margin:24px auto 0;padding:0 24px;min-height:0;contain:layout;">
    <div style="background:var(--accent-light);border-radius:14px;padding:16px 20px;">
      <div style="font-size:.78rem;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;">Welcome back — your last results</div>
      <div id="returning-results" style="display:flex;flex-wrap:wrap;gap:8px;"></div>
    </div>
  </div>

  <div class="hero">
    <h1>Check Your BMI<br><em>in 10 Seconds</em></h1>
    <p>Enter your height and weight — get your BMI, category, and healthy weight range instantly.</p>

    <!-- Inline BMI Calculator -->
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;max-width:420px;margin:28px auto 0;box-shadow:0 4px 24px rgba(26,23,20,.08);text-align:left;">

      <!-- Unit toggle -->
      <div style="display:flex;gap:8px;margin-bottom:20px;">
        <button id="hero-unit-metric" onclick="heroSetUnit('metric')"
          style="flex:1;padding:9px 0;border-radius:8px;border:1.5px solid var(--accent);background:var(--accent);color:#fff;font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit;">
          Metric (kg/cm)
        </button>
        <button id="hero-unit-imperial" onclick="heroSetUnit('imperial')"
          style="flex:1;padding:9px 0;border-radius:8px;border:1.5px solid var(--border);background:transparent;color:var(--ink2);font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit;">
          Imperial (lb/in)
        </button>
      </div>

      <!-- Metric inputs -->
      <div id="hero-metric-inputs">
        <div style="display:flex;gap:10px;margin-bottom:12px;">
          <div style="flex:1;">
            <label for="hero-weight-kg" style="font-size:.78rem;font-weight:600;color:var(--ink2);display:block;margin-bottom:4px;">Weight (kg)</label>
            <input id="hero-weight-kg" type="number" placeholder="e.g. 70" min="20" max="300"
              style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:.95rem;font-family:inherit;background:var(--bg);color:var(--ink);box-sizing:border-box;">
          </div>
          <div style="flex:1;">
            <label for="hero-height-cm" style="font-size:.78rem;font-weight:600;color:var(--ink2);display:block;margin-bottom:4px;">Height (cm)</label>
            <input id="hero-height-cm" type="number" placeholder="e.g. 170" min="100" max="250"
              style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:.95rem;font-family:inherit;background:var(--bg);color:var(--ink);box-sizing:border-box;">
          </div>
        </div>
      </div>

      <!-- Imperial inputs -->
      <div id="hero-imperial-inputs" style="display:none;">
        <div style="display:flex;gap:10px;margin-bottom:12px;">
          <div style="flex:1;">
            <label for="hero-weight-lb" style="font-size:.78rem;font-weight:600;color:var(--ink2);display:block;margin-bottom:4px;">Weight (lb)</label>
            <input id="hero-weight-lb" type="number" placeholder="e.g. 154" min="44" max="660"
              style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:.95rem;font-family:inherit;background:var(--bg);color:var(--ink);box-sizing:border-box;">
          </div>
          <div style="flex:1;">
            <label for="hero-height-in" style="font-size:.78rem;font-weight:600;color:var(--ink2);display:block;margin-bottom:4px;">Height (in)</label>
            <input id="hero-height-in" type="number" placeholder="e.g. 67" min="40" max="96"
              style="width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:.95rem;font-family:inherit;background:var(--bg);color:var(--ink);box-sizing:border-box;">
          </div>
        </div>
      </div>

      <!-- Calculate button -->
      <button onclick="heroCalc()"
        style="width:100%;padding:13px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:1rem;font-weight:600;cursor:pointer;font-family:inherit;margin-bottom:14px;">
        Calculate BMI →
      </button>

      <!-- Result (hidden until calculated) -->
      <div id="hero-result" style="display:none;border-top:1px solid var(--border);padding-top:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <span style="font-size:.82rem;color:var(--ink2);">Your BMI</span>
          <span id="hero-bmi-val" style="font-size:1.6rem;font-weight:700;font-family:'DM Serif Display',serif;"></span>
        </div>
        <div id="hero-bmi-badge" style="display:inline-block;padding:4px 14px;border-radius:100px;font-size:.82rem;font-weight:600;margin-bottom:10px;"></div>
        <div id="hero-healthy-range" style="font-size:.82rem;color:var(--ink2);margin-bottom:12px;"></div>
        <a href="bmi-calculator.html" style="font-size:.82rem;color:var(--accent);text-decoration:none;font-weight:500;">See full results + health tips →</a>
      </div>

      <!-- Error message -->
      <div id="hero-error" style="display:none;font-size:.82rem;color:#B83232;margin-top:-8px;margin-bottom:4px;">Please enter valid height and weight.</div>
    </div>

    <!-- Trust badges — smaller, below calculator -->
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:18px auto 0;max-width:420px;">
      <span style="font-size:.75rem;color:var(--ink3);">🔬 WHO formulas</span>
      <span style="font-size:.75rem;color:var(--ink3);">·</span>
      <span style="font-size:.75rem;color:var(--ink3);">🔒 No data stored</span>
      <span style="font-size:.75rem;color:var(--ink3);">·</span>
      <span style="font-size:.75rem;color:var(--ink3);">⚡ Instant results</span>
    </div>
  </div>

  <script>
  var heroUnit = 'metric';

  function heroSetUnit(u) {
    heroUnit = u;
    var metricBtn   = document.getElementById('hero-unit-metric');
    var imperialBtn = document.getElementById('hero-unit-imperial');
    var metricIn    = document.getElementById('hero-metric-inputs');
    var imperialIn  = document.getElementById('hero-imperial-inputs');
    var active   = 'flex:1;padding:9px 0;border-radius:8px;border:1.5px solid var(--accent);background:var(--accent);color:#fff;font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit;';
    var inactive = 'flex:1;padding:9px 0;border-radius:8px;border:1.5px solid var(--border);background:transparent;color:var(--ink2);font-size:.85rem;font-weight:600;cursor:pointer;font-family:inherit;';
    if (u === 'metric') {
      metricBtn.style.cssText = active;
      imperialBtn.style.cssText = inactive;
      metricIn.style.display = 'block';
      imperialIn.style.display = 'none';
    } else {
      metricBtn.style.cssText = inactive;
      imperialBtn.style.cssText = active;
      metricIn.style.display = 'none';
      imperialIn.style.display = 'block';
    }
    document.getElementById('hero-result').style.display = 'none';
    document.getElementById('hero-error').style.display = 'none';
  }

  function heroCalc() {
    var bmi, w, h;
    var err = document.getElementById('hero-error');
    var res = document.getElementById('hero-result');
    err.style.display = 'none';
    res.style.display = 'none';

    if (heroUnit === 'metric') {
      w = parseFloat(document.getElementById('hero-weight-kg').value);
      h = parseFloat(document.getElementById('hero-height-cm').value) / 100;
    } else {
      w = parseFloat(document.getElementById('hero-weight-lb').value);
      h = parseFloat(document.getElementById('hero-height-in').value);
      bmi = (w / (h * h)) * 703;
    }

    if (heroUnit === 'metric') bmi = w / (h * h);

    if (!bmi || bmi < 10 || bmi > 80 || isNaN(bmi)) {
      err.style.display = 'block';
      return;
    }

    bmi = Math.round(bmi * 10) / 10;

    var cat, color, hRange;
    if (bmi < 18.5) {
      cat = 'Underweight'; color = '#3A7BBF';
    } else if (bmi < 25) {
      cat = 'Normal weight'; color = '#2D6A4F';
    } else if (bmi < 30) {
      cat = 'Overweight'; color = '#C17B2A';
    } else {
      cat = 'Obese'; color = '#B83232';
    }

    // Healthy weight range for their height
    var hMin, hMax;
    if (heroUnit === 'metric') {
      hMin = Math.round(18.5 * h * h * 10) / 10;
      hMax = Math.round(24.9 * h * h * 10) / 10;
      hRange = 'Healthy range for your height: ' + hMin + ' – ' + hMax + ' kg';
    } else {
      var hIn = parseFloat(document.getElementById('hero-height-in').value);
      hMin = Math.round(18.5 * hIn * hIn / 703 * 10) / 10;
      hMax = Math.round(24.9 * hIn * hIn / 703 * 10) / 10;
      hRange = 'Healthy range for your height: ' + hMin + ' – ' + hMax + ' lb';
    }

    document.getElementById('hero-bmi-val').textContent = bmi;
    var badge = document.getElementById('hero-bmi-badge');
    badge.textContent = cat;
    badge.style.cssText = 'display:inline-block;padding:4px 14px;border-radius:100px;font-size:.82rem;font-weight:600;margin-bottom:10px;background:' + color + '22;color:' + color + ';';
    document.getElementById('hero-healthy-range').textContent = hRange;
    res.style.display = 'block';
  }
  </script>

  <!-- Calculators -->
  <section class="section">
    <p class="section-label">Free Calculators</p>
    <h2 class="section-title">Know Your Numbers</h2>

    <!-- Tab buttons -->
    <div class="calc-tabs">
      <button class="calc-tab active" onclick="showTab('all',this)">All Tools</button>
      <button class="calc-tab" onclick="showTab('bmi',this)">⚖️ BMI</button>
      <button class="calc-tab" onclick="showTab('calories',this)">🔥 Calories</button>
      <button class="calc-tab" onclick="showTab('body',this)">📊 Body</button>
      <button class="calc-tab" onclick="showTab('hydration',this)">💧 Hydration</button>
    </div>

    <!-- BMI Panel -->
    <!-- All Tools Panel (default) -->
    <div class="calc-panel active" id="tab-all">
      <a class="tool-card" href="bmi-calculator.html">
        <div class="tool-icon">⚖️</div>
        <h2>BMI Calculator</h2>
        <p>Find out if your weight is in a healthy range for your height. Instant results, metric &amp; imperial.</p>
        <span class="tool-link">Calculate BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="calorie-calculator.html">
        <div class="tool-icon">🔥</div>
        <h2>Calorie Calculator</h2>
        <p>Estimate your daily calorie needs based on your age, weight, height, and activity level.</p>
        <span class="tool-link">Calculate Calories <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="bmr-calculator.html">
        <div class="tool-icon">⚡</div>
        <h2>BMR Calculator</h2>
        <p>Find out how many calories your body burns at rest — the foundation of any weight loss plan.</p>
        <span class="tool-link">Calculate BMR <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
            <a class="tool-card" href="calorie-deficit-calculator.html">
        <div class="tool-icon">📉</div>
        <h2>Calorie Deficit Calculator</h2>
        <p>Set your goal weight and rate of loss — get your daily calorie target and time to reach it.</p>
        <span class="tool-link">Calculate Deficit <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="ideal-weight.html">
        <div class="tool-icon">🎯</div>
        <h2>Ideal Weight Calculator</h2>
        <p>Discover your ideal weight range based on your height and body frame using multiple formulas.</p>
        <span class="tool-link">Find Ideal Weight <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="body-fat.html">
        <div class="tool-icon">📊</div>
        <h2>Body Fat Calculator</h2>
        <p>Estimate your body fat percentage using body measurements. Understand lean mass vs. fat mass.</p>
        <span class="tool-link">Calculate Body Fat <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="water-intake.html">
        <div class="tool-icon">💧</div>
        <h2>Water Intake Calculator</h2>
        <p>Find out how much water to drink daily based on your weight, activity, and climate.</p>
        <span class="tool-link">Calculate Water Intake <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="macro-calculator.html">
        <div class="tool-icon">🥗</div>
        <h2>Macro Calculator</h2>
        <p>Daily protein, carbs, and fat targets based on your goal — fat loss, maintenance, or muscle gain.</p>
        <span class="tool-link">Calculate Macros <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="asian-bmi-calculator.html">
        <div class="tool-icon">🌏</div>
        <h2>Asian BMI Calculator</h2>
        <p>BMI thresholds adjusted for Asian adults — overweight at 23, obese at 27.5.</p>
        <span class="tool-link">Calculate Asian BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="bmi-calculator-kids.html">
        <div class="tool-icon">👶</div>
        <h2>Kids BMI Calculator</h2>
        <p>Child BMI using CDC percentile charts for boys and girls aged 2–17.</p>
        <span class="tool-link">Calculate Child BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="waist-to-height-ratio.html">
        <div class="tool-icon">📏</div>
        <h2>Waist-to-Height Ratio</h2>
        <p>A more accurate predictor of metabolic risk than BMI. Keep your waist under half your height.</p>
        <span class="tool-link">Calculate WHtR <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>

        <div class="calc-panel" id="tab-bmi">
      <a class="tool-card" href="bmi-calculator.html">
        <div class="tool-icon">⚖️</div>
        <h2>BMI Calculator</h2>
        <p>Find out if your weight is in a healthy range for your height. Instant results, metric &amp; imperial.</p>
        <span class="tool-link">Calculate BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="asian-bmi-calculator.html">
        <div class="tool-icon">🌏</div>
        <h2>Asian BMI Calculator</h2>
        <p>BMI thresholds adjusted for Asian adults — overweight starts at 23, obese at 27.5. More accurate for Asian populations.</p>
        <span class="tool-link">Calculate Asian BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="bmi-calculator-kids.html">
        <div class="tool-icon">👶</div>
        <h2>Kids BMI Calculator</h2>
        <p>Child BMI using CDC percentile charts for boys and girls aged 2–17. Not the same as adult BMI.</p>
        <span class="tool-link">Calculate Child BMI <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="waist-to-height-ratio.html">
        <div class="tool-icon">📏</div>
        <h2>Waist-to-Height Ratio</h2>
        <p>A more accurate predictor of metabolic risk than BMI. Aim to keep your waist under half your height.</p>
        <span class="tool-link">Calculate WHtR <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>

    <!-- Calories Panel -->
    <div class="calc-panel" id="tab-calories">
      <a class="tool-card" href="calorie-calculator.html">
        <div class="tool-icon">🔥</div>
        <h2>Calorie Calculator</h2>
        <p>Estimate your daily calorie needs based on your age, weight, height, and activity level.</p>
        <span class="tool-link">Calculate Calories <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="calorie-deficit-calculator.html">
        <div class="tool-icon">📉</div>
        <h2>Calorie Deficit Calculator</h2>
        <p>Set your goal weight and rate of loss — get your daily calorie target and estimated time to reach it.</p>
        <span class="tool-link">Calculate Deficit <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="macro-calculator.html">
        <div class="tool-icon">🥗</div>
        <h2>Macro Calculator</h2>
        <p>Daily protein, carbs, and fat targets based on your goal — fat loss, maintenance, or muscle gain.</p>
        <span class="tool-link">Calculate Macros <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>

    <!-- Body Panel -->
    <div class="calc-panel" id="tab-body">
      <a class="tool-card" href="body-fat.html">
        <div class="tool-icon">📊</div>
        <h2>Body Fat Calculator</h2>
        <p>Estimate your body fat percentage using body measurements. Understand your lean mass vs. fat mass.</p>
        <span class="tool-link">Calculate Body Fat <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="tool-card" href="ideal-weight.html">
        <div class="tool-icon">🎯</div>
        <h2>Ideal Weight Calculator</h2>
        <p>Discover your ideal weight range based on your height and body frame using multiple formulas.</p>
        <span class="tool-link">Find Ideal Weight <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>

    <!-- Hydration Panel -->
    <div class="calc-panel" id="tab-hydration">
      <a class="tool-card" href="water-intake.html">
        <div class="tool-icon">💧</div>
        <h2>Water Intake Calculator</h2>
        <p>Find out how much water you should drink daily based on your weight, activity level, and climate.</p>
        <span class="tool-link">Calculate Water Intake <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="#2D6A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>

  </section>


  <!-- Goal Quiz -->
  <div class="featured-section" id="goal-quiz-section">
    <div style="background:var(--surface);border-radius:16px;padding:20px 22px;box-shadow:var(--shadow);max-width:640px;margin:0 auto;">
      <div style="height:3px;background:var(--border);border-radius:2px;margin-bottom:16px;overflow:hidden;">
        <div id="quiz-progress-bar" style="height:100%;background:var(--accent);border-radius:2px;width:0%;transition:width .4s ease;"></div>
      </div>

      <!-- Step 1 -->
      <div id="quiz-step-1">
        <div style="font-size:.75rem;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;">Step 1 of 3</div>
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.25rem;margin-bottom:12px;line-height:1.2;">What's your main health goal?</h2>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          <button class="quiz-opt" onclick="quizAnswer(1,'lose')" data-val="lose">📉 Lose fat</button>
          <button class="quiz-opt" onclick="quizAnswer(1,'muscle')" data-val="muscle">💪 Build muscle</button>
          <button class="quiz-opt" onclick="quizAnswer(1,'health')" data-val="health">❤️ Check my health</button>
          <button class="quiz-opt" onclick="quizAnswer(1,'understand')" data-val="understand">📊 Full profile</button>
        </div>
      </div>

