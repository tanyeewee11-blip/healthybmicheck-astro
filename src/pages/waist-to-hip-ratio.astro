---
import Base from '../layouts/Base.astro';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Waist-to-Hip Ratio Calculator — WHO Risk Categories",
      "description": "Free waist-to-hip ratio calculator using WHO thresholds. WHR estimates cardiovascular and metabolic health risk based on fat distribution. Instant results.",
      "author": { "@type": "Organization", "name": "HealthyBMICheck.com" },
      "publisher": { "@type": "Organization", "name": "HealthyBMICheck.com", "url": "https://healthybmicheck.com" },
      "datePublished": "2026-07-05",
      "dateModified": "2026-07-05",
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://healthybmicheck.com/waist-to-hip-ratio.html" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a healthy waist-to-hip ratio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "According to WHO thresholds, a healthy waist-to-hip ratio is below 0.90 for men and below 0.80 for women. A ratio of 0.90-0.99 (men) or 0.80-0.84 (women) indicates moderate risk, and 1.00 or above (men) or 0.85 or above (women) indicates substantially increased health risk."
          }
        },
        {
          "@type": "Question",
          "name": "How is waist-to-hip ratio calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Waist-to-hip ratio is your waist circumference divided by your hip circumference, both measured in the same unit: WHR = Waist ÷ Hip. For example, someone with an 80 cm waist and 100 cm hips has a WHR of 0.80."
          }
        },
        {
          "@type": "Question",
          "name": "Is waist-to-hip ratio better than BMI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "WHR and BMI measure different things. BMI reflects overall weight relative to height, while WHR reflects fat distribution — specifically, how much fat is stored around the abdomen versus the hips. Research suggests WHR is a stronger predictor of cardiovascular risk than BMI alone, since abdominal (visceral) fat is more metabolically harmful than fat stored elsewhere. Using both together, alongside our BMI calculator, gives the fullest picture."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between waist-to-hip ratio and waist-to-height ratio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Both measure abdominal fat distribution, but waist-to-height ratio (WHtR) compares waist size to height, while waist-to-hip ratio (WHR) compares waist size to hip size. WHtR uses a single universal threshold (0.5) for all adults, while WHR uses separate thresholds for men and women since hip size differs by sex. Both are useful complements to BMI."
          }
        },
        {
          "@type": "Question",
          "name": "How do I measure my hips correctly?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Stand with feet together and wrap a flexible tape measure around the widest part of your buttocks/hips, keeping the tape level and snug but not compressing the skin. Take two readings and average them for accuracy."
          }
        }
      ]
    },
    {
      "@type": "WebApplication",
      "name": "Waist-to-Hip Ratio Calculator",
      "url": "https://healthybmicheck.com/waist-to-hip-ratio.html",
      "description": "Calculate waist-to-hip ratio and cardiometabolic risk category using WHO thresholds.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web Browser",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "publisher": { "@type": "Organization", "name": "HealthyBMICheck.com", "url": "https://healthybmicheck.com" }
    },
    {
      "@type": "HowTo",
      "name": "How to Calculate Your Waist-to-Hip Ratio",
      "description": "Measure your waist-to-hip ratio — a WHO-recognized predictor of cardiometabolic risk based on fat distribution.",
      "totalTime": "PT2M",
      "tool": [
        { "@type": "HowToTool", "name": "HealthyBMICheck Waist-to-Hip Ratio Calculator" },
        { "@type": "HowToTool", "name": "Measuring tape" }
      ],
      "step": [
        { "@type": "HowToStep", "name": "Measure your waist", "text": "Wrap a tape around your waist at the midpoint between your lowest rib and the top of your hip bone. Breathe out normally and measure." },
        { "@type": "HowToStep", "name": "Measure your hips", "text": "Wrap a tape around the widest part of your hips/buttocks, keeping it level." },
        { "@type": "HowToStep", "name": "Select your sex", "text": "WHO risk thresholds differ for men and women." },
        { "@type": "HowToStep", "name": "Read your ratio and risk level", "text": "Your waist-to-hip ratio and WHO risk category are displayed instantly." }
      ]
    }
  ]
});

const breadcrumbJson = JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://healthybmicheck.com/"},{"@type":"ListItem","position":2,"name":"Waist-to-Hip Ratio Calculator","item":"https://healthybmicheck.com/waist-to-hip-ratio.html"}]});
---

<Base
  breadcrumbJson={breadcrumbJson}
  schemaJson={schemaJson}
  title="Waist-to-Hip Ratio Calculator — WHO Risk Categories (Free)"
  description="Free waist-to-hip ratio calculator using WHO thresholds. WHR estimates cardiovascular and metabolic health risk based on fat distribution."
  canonical="https://healthybmicheck.com/waist-to-hip-ratio.html"
>
<div class="hero">
    <div class="breadcrumb" class="input-hint"><a href="index.html" class="breadcrumb-link">Home</a> › Waist-to-Hip Ratio Calculator</div>
  <h1>Waist-to-Hip<br><em>Ratio Calculator</em></h1>
  <p>WHR measures how your body stores fat — a WHO-recognized predictor of cardiovascular and metabolic risk, alongside BMI.</p>
</div>

<div class="calc-byline">Reviewed by <strong>Sarah Mitchell, BSc Nutrition</strong> · Last updated: <strong>July 2026</strong></div>

<div class="container">

  <div class="card">
    <div class="unit-toggle">
      <button class="active" onclick="setUnit('metric')">Metric (cm)</button>
      <button onclick="setUnit('imperial')">Imperial (inches)</button>
    </div>

    <div class="input-group">
      <label>Sex</label>
      <div class="gender-toggle">
        <button class="gender-btn active" onclick="setGender('male', this)">♂ Male</button>
        <button class="gender-btn" onclick="setGender('female', this)">♀ Female</button>
      </div>
    </div>

    <div class="input-group">
      <label>Waist Circumference</label>
      <div class="input-wrap">
        <input type="number" id="waist" placeholder="80" min="40" max="200">
        <span class="unit-badge" id="waist-unit">cm</span>
      </div>
      <div class="input-hint">Measure at the midpoint between your lowest rib and the top of your hip bone. <a href="#how-to-measure" class="text-accent">How to measure →</a></div>
    </div>

    <div class="input-group">
      <label>Hip Circumference</label>
      <div class="input-wrap">
        <input type="number" id="hip" placeholder="100" min="40" max="200">
        <span class="unit-badge" id="hip-unit">cm</span>
      </div>
      <div class="input-hint">Measure at the widest part of your hips/buttocks.</div>
    </div>

    <button class="calc-btn" onclick="calculate()">Calculate WHR →</button>
  </div>

  <!-- Result -->
  <div class="result-card" id="result-card">
    <div class="whtr-number" id="whr-number">—</div>
    <div class="bmi-category" id="result-category"></div>

    <div class="gauge-wrap">
      <div class="gauge-bar">
        <div class="gauge-pointer" id="gauge-pointer" style="left:0%"></div>
      </div>
      <div class="gauge-labels" id="gauge-labels">
        <span>Low risk</span>
        <span>Moderate</span>
        <span>High risk</span>
      </div>
    </div>

    <div class="tip-box">
      <strong>Next step:</strong> Pair this with your
      <a href="bmi-calculator.html" class="text-accent-bold">BMI</a> and
      <a href="body-fat.html" class="text-accent-bold">body fat percentage</a> for a fuller picture of your health.
    </div>
  </div>

  <!-- How to measure -->
  <div class="measure-card" id="how-to-measure">
    <h2 class="section-title">How to Measure Correctly</h2>
    <p style="color:var(--ink2);font-size:0.9rem;margin-top:8px;">A 2 cm error in either measurement can meaningfully change your result.</p>
    <div class="measure-steps">
      <div class="measure-step">
        <div class="step-num">1</div>
        <div class="step-text">Waist: find the midpoint between your lowest rib and the top of your hip bone (roughly navel level)</div>
      </div>
      <div class="measure-step">
        <div class="step-num">2</div>
        <div class="step-text">Hips: wrap the tape around the widest part of your hips/buttocks, keeping it level</div>
      </div>
      <div class="measure-step">
        <div class="step-num">3</div>
        <div class="step-text">Stand relaxed, feet together, breathe out gently. Measure over bare skin, not clothing. Take two readings and average them</div>
      </div>
    </div>
  </div>

  <!-- WHR Reference Table -->
  <div>
    <h2 class="section-title">WHO Waist-to-Hip Ratio Risk Categories</h2>
    <p class="section-sub">Thresholds differ by sex.</p>
    <div class="card" class="overflow-clip">
      <table>
        <thead>
          <tr><th>Category</th><th>Men</th><th>Women</th></tr>
        </thead>
        <tbody>
          <tr><td><span class="dot" style="background:#2D6A4F"></span>Low risk</td><td>&lt; 0.90</td><td>&lt; 0.80</td></tr>
          <tr class="highlight-row"><td><span class="dot" style="background:#C17B2A"></span>Moderate risk</td><td>0.90 – 0.99</td><td>0.80 – 0.84</td></tr>
          <tr><td><span class="dot" style="background:#B83232"></span>High risk</td><td>≥ 1.00</td><td>≥ 0.85</td></tr>
        </tbody>
      </table>
    </div>
    <p class="input-hint">Source: World Health Organization, Waist Circumference and Waist-Hip Ratio: Report of a WHO Expert Consultation (2011).</p>
  </div>

  <!-- FAQ -->
  <div class="faq-section" id="faq" style="margin-top:20px;">
    <h2 class="section-title">Frequently Asked Questions</h2>

    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">What is a healthy waist-to-hip ratio?</button>
      <div class="faq-a">According to WHO thresholds, a healthy waist-to-hip ratio is below 0.90 for men and below 0.80 for women. A ratio of 0.90–0.99 (men) or 0.80–0.84 (women) indicates moderate risk, and 1.00 or above (men) or 0.85 or above (women) indicates substantially increased health risk.</div>
    </div>

    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">How is waist-to-hip ratio calculated?</button>
      <div class="faq-a">Waist-to-hip ratio is your waist circumference divided by your hip circumference, both measured in the same unit:<br><br><strong>WHR = Waist ÷ Hip</strong><br><br>For example, someone with an 80 cm waist and 100 cm hips has a WHR of 80 ÷ 100 = 0.80.</div>
    </div>

    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">Is waist-to-hip ratio better than BMI?</button>
      <div class="faq-a">WHR and BMI measure different things. BMI reflects overall weight relative to height, while WHR reflects fat distribution — specifically, how much fat is stored around the abdomen versus the hips. Research suggests WHR is a stronger predictor of cardiovascular risk than BMI alone, since abdominal (visceral) fat is more metabolically harmful than fat stored elsewhere. Using both together, alongside our <a href="bmi-calculator.html">BMI calculator</a>, gives the fullest picture.</div>
    </div>

    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">What is the difference between waist-to-hip ratio and waist-to-height ratio?</button>
      <div class="faq-a">Both measure abdominal fat distribution, but waist-to-height ratio (WHtR) compares waist size to height, while waist-to-hip ratio (WHR) compares waist size to hip size. WHtR uses a single universal threshold (0.5) for all adults, while WHR uses separate thresholds for men and women since hip size differs by sex. Both are useful complements to BMI — see also our <a href="waist-to-height-ratio.html">Waist-to-Height Ratio Calculator</a>.</div>
    </div>

    <div class="faq-item">
      <button class="faq-q" onclick="toggleFaq(this)">How do I measure my hips correctly?</button>
      <div class="faq-a">Stand with feet together and wrap a flexible tape measure around the widest part of your buttocks/hips, keeping the tape level and snug but not compressing the skin. Take two readings and average them for accuracy.</div>
    </div>
  </div>

  <!-- Article -->
  <div class="article-section">
    <h2>Why Where You Store Fat Matters</h2>
    <p>Two people can have the exact same weight and BMI, yet very different health risks — depending on where their body stores fat. Fat stored around the abdomen (sometimes called an "apple" body shape) surrounds and infiltrates organs like the liver and pancreas, and is far more metabolically active than fat stored around the hips and thighs (a "pear" body shape).</p>
    <p>Waist-to-hip ratio captures this difference directly by comparing the two measurements. A higher WHR indicates proportionally more fat carried around the abdomen relative to the hips — a pattern linked to greater cardiovascular and metabolic risk regardless of total body weight.</p>

    <div class="callout"><p>💡 <strong>Apple vs pear:</strong> "Apple-shaped" fat distribution (higher WHR) is associated with greater cardiometabolic risk than "pear-shaped" distribution (lower WHR), even at the same total body weight.</p></div>

    <h2>WHR vs Waist-to-Height Ratio vs BMI</h2>
    <p>These three metrics each capture something different, and using them together gives a more complete picture than any one alone:</p>
    <ul>
      <li><strong>BMI</strong> reflects overall weight relative to height but cannot show fat distribution or distinguish fat from muscle.</li>
      <li><strong>Waist-to-hip ratio (WHR)</strong> compares abdominal fat to hip/gluteal fat — useful for capturing "apple vs pear" body shape, with sex-specific WHO thresholds.</li>
      <li><strong>Waist-to-height ratio (WHtR)</strong> compares abdominal fat to overall height, using one universal 0.5 threshold for all adults. Try our <a href="waist-to-height-ratio.html">Waist-to-Height Ratio Calculator</a>.</li>
    </ul>
    <p>For the most complete picture of your health, check your <a href="bmi-calculator.html">BMI</a>, WHR, and <a href="body-fat.html">body fat percentage</a> together rather than relying on any single number.</p>

    <h2>Can I Lower My Waist-to-Hip Ratio?</h2>
    <p>Since WHR is driven mainly by abdominal fat, the same strategies that reduce visceral fat generally improve WHR over time:</p>
    <ul>
      <li>A consistent moderate calorie deficit — use our <a href="calorie-calculator.html">Calorie Calculator</a> to find your target.</li>
      <li>Regular aerobic exercise (150–300 minutes/week of moderate cardio).</li>
      <li>Strength training to preserve muscle and support metabolism.</li>
      <li>Adequate sleep and stress management, since both affect abdominal fat storage.</li>
    </ul>
    <p>Body fat distribution also has a genetic component that can't be changed through lifestyle alone — WHR is a useful tracking tool, not a target to chase at any cost.</p>

    <div class="sources">
      <strong>References:</strong><br>
      World Health Organization. Waist Circumference and Waist-Hip Ratio: Report of a WHO Expert Consultation. Geneva, 2011.<br>
      Yusuf S, et al. Obesity and the risk of myocardial infarction in 27,000 participants from 52 countries: a case-control study. <em>The Lancet</em>. 2005;366(9497):1640–1649.
    </div>

    <div class="related">
      <h3>Related Tools &amp; Articles</h3>
      <div class="related-links">
        <a href="bmi-calculator.html">BMI Calculator</a>
        <a href="waist-to-height-ratio.html">Waist-to-Height Ratio Calculator</a>
        <a href="body-fat.html">Body Fat Calculator</a>
        <a href="calorie-calculator.html">Calorie Calculator</a>
        <a href="ideal-weight.html">Ideal Weight Calculator</a>
        <a href="what-is-bmi.html">What Is BMI?</a>
      </div>
    </div>
  </div>

</div>

<!-- CTA Block -->
<div class="container">
  <div class="cta-inner">
    <p class="cta-label">Next step</p>
    <h2 class="cta-h2">Complete your health assessment</h2>
    <p class="cta-sub">Check your BMI, body fat percentage, and daily calorie needs.</p>
    <div class="cta-btns">
      <a href="bmi-calculator.html" class="cta-btn-p">⚖️ BMI Calculator →</a>
      <a href="body-fat.html" class="cta-btn-s">📊 Body Fat Calculator →</a>
      <a href="waist-to-height-ratio.html" class="cta-btn-s">📏 Waist-to-Height Ratio →</a>
    </div>
  </div>
</div>

<script>
let unit = 'metric';
let gender = 'male';

function setUnit(u) {
  unit = u;
  document.querySelectorAll('.unit-toggle button').forEach((b,i) => b.classList.toggle('active', (u==='metric'&&i===0)||(u==='imperial'&&i===1)));
  document.getElementById('waist-unit').textContent = u === 'metric' ? 'cm' : 'in';
  document.getElementById('hip-unit').textContent = u === 'metric' ? 'cm' : 'in';
}

function setGender(g, btn) {
  gender = g;
  document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function calculate() {
  let waist = parseFloat(document.getElementById('waist').value);
  let hip = parseFloat(document.getElementById('hip').value);

  if (!waist || !hip) {
    alert('Please enter both waist and hip measurements.');
    return;
  }

  const whr = waist / hip;
  let category, color, pointerPct;

  if (gender === 'male') {
    if (whr < 0.90) { category = 'Low risk'; color = '#2D6A4F'; }
    else if (whr < 1.00) { category = 'Moderate risk'; color = '#C17B2A'; }
    else { category = 'High risk'; color = '#B83232'; }
    pointerPct = Math.min(100, Math.max(0, ((whr - 0.70) / (1.20 - 0.70)) * 100));
  } else {
    if (whr < 0.80) { category = 'Low risk'; color = '#2D6A4F'; }
    else if (whr < 0.85) { category = 'Moderate risk'; color = '#C17B2A'; }
    else { category = 'High risk'; color = '#B83232'; }
    pointerPct = Math.min(100, Math.max(0, ((whr - 0.60) / (1.10 - 0.60)) * 100));
  }

  document.getElementById('whr-number').textContent = whr.toFixed(2);
  document.getElementById('whr-number').style.color = color;
  document.getElementById('result-category').textContent = category + ' (' + (gender === 'male' ? 'male' : 'female') + ' thresholds)';
  document.getElementById('result-category').style.color = color;
  document.getElementById('gauge-pointer').style.left = pointerPct + '%';
  document.getElementById('gauge-pointer').style.background = color;

  document.getElementById('result-card').classList.add('visible');
  document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}
</script>

</Base>
