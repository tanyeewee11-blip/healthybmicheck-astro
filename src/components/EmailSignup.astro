---
// EmailSignup.astro
// Usage: <EmailSignup context="calorie" /> — context customises the headline
// Connects to Mailchimp via their embedded form (no JS library needed)
// Replace ACTION_URL below with your Mailchimp form action URL after setup

interface Props {
  context?: 'bmi' | 'calorie' | 'weight' | 'water' | 'general';
  compact?: boolean;
}

const { context = 'general', compact = false } = Astro.props;

const headlines: Record<string, { title: string; sub: string }> = {
  bmi:     { title: "Get your free BMI report",       sub: "Weekly tips on healthy weight, BMI, and body composition — no spam, unsubscribe anytime." },
  calorie: { title: "Free weekly calorie guide",      sub: "Evidence-based nutrition and calorie tips every week. Unsubscribe anytime." },
  weight:  { title: "Free weight loss tips",          sub: "Practical, evidence-based advice on losing weight safely — delivered weekly." },
  water:   { title: "Free hydration & health tips",   sub: "Simple, science-backed health habits delivered to your inbox weekly." },
  general: { title: "Free weekly health tips",        sub: "Evidence-based guides on BMI, weight, calories, and nutrition. Unsubscribe anytime." },
};

const { title, sub } = headlines[context] ?? headlines.general;
---

<div class={compact ? "email-signup email-signup--compact" : "email-signup"}>
  <div class="email-signup__inner">
    <div class="email-signup__text">
      <p class="email-signup__label">📬 Newsletter</p>
      <h3 class="email-signup__title">{title}</h3>
      {!compact && <p class="email-signup__sub">{sub}</p>}
    </div>

    <!-- Replace action URL with your Mailchimp embed URL -->
    <!-- Get it from: Mailchimp → Audience → Signup forms → Embedded forms → copy action URL -->
    <form
      class="email-signup__form"
      action="https://YOUR_MAILCHIMP_FORM_ACTION_URL"
      method="post"
      target="_blank"
      novalidate
    >
      <!-- Mailchimp anti-bot honeypot field — do not remove -->
      <div style="position:absolute;left:-5000px;" aria-hidden="true">
        <input type="text" name="b_XXXXX_XXXXX" tabindex="-1" value="">
      </div>

      <div class="email-signup__row">
        <input
          type="email"
          name="EMAIL"
          placeholder="your@email.com"
          required
          class="email-signup__input"
          aria-label="Email address"
        >
        <button type="submit" class="email-signup__btn">
          Subscribe →
        </button>
      </div>
      <p class="email-signup__note">Free · No spam · Unsubscribe anytime</p>
    </form>
  </div>
</div>

<style>
  .email-signup {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
    margin: 32px 0;
  }

  .email-signup--compact {
    padding: 20px;
    margin: 20px 0;
    border-radius: 12px;
  }

  .email-signup__inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .email-signup__label {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .email-signup__title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.3rem;
    line-height: 1.2;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .email-signup--compact .email-signup__title {
    font-size: 1.05rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
  }

  .email-signup__sub {
    font-size: .875rem;
    color: var(--ink2);
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .email-signup__form {
    position: relative;
    margin-top: 16px;
  }

  .email-signup__row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .email-signup__input {
    flex: 1;
    min-width: 200px;
    padding: 11px 16px;
    border: 1.5px solid var(--border);
    border-radius: 100px;
    font-size: .9rem;
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--ink);
    outline: none;
    transition: border-color .15s;
  }

  .email-signup__input:focus {
    border-color: var(--accent);
  }

  .email-signup__input::placeholder {
    color: var(--ink3);
  }

  .email-signup__btn {
    padding: 11px 22px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 100px;
    font-size: .875rem;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .15s;
  }

  .email-signup__btn:hover {
    opacity: .88;
  }

  .email-signup__note {
    font-size: .72rem;
    color: var(--ink3);
    margin-top: 10px;
    text-align: center;
  }

  @media (max-width: 480px) {
    .email-signup__row {
      flex-direction: column;
    }
    .email-signup__input,
    .email-signup__btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
